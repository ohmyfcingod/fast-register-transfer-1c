#Область ПрограммныйИнтерфейс

// Тонкие обёртки - ТОЧКИ ВХОДА для фоновых заданий. Сама логика живёт в модуле менеджера
// обработки БыстрыйПереносРегистров; сюда вынесены только вызовы, потому что фоновое задание
// не умеет адресовать метод модуля менеджера обработки по имени (а метод общего модуля - умеет).

Процедура ВыгрузитьДиапазон(ПолноеИмя, ИмяРегистра, Папка, Поле, Лево, Право, Последний, НомерПотока, РазмерПорции, Сжатие = 0) Экспорт
	Обработки.БыстрыйПереносРегистров.ВыгрузитьДиапазонРегистраФон(
		ПолноеИмя, ИмяРегистра, Папка, Поле, Лево, Право, Последний, НомерПотока, РазмерПорции, Сжатие);
КонецПроцедуры

Процедура ЗагрузитьПорции(ИмяРегистра, Папка, МассивФайлов, НомерПотока = 0) Экспорт
	Обработки.БыстрыйПереносРегистров.ЗагрузитьПорцииНезависимыйФон(ИмяРегистра, Папка, МассивФайлов, НомерПотока);
КонецПроцедуры

// Полный перенос фоновым заданием (живой прогресс в форме: _план/_прогресс_*/_итог в папке обмена).

Процедура ВыгрузитьВсё(МассивИмён, Папка, РазмерПорции, ЧислоПотоков, Сжатие, ФорматДанных,
		НачалоПериода = '00010101', КонецПериода = '00010101') Экспорт
	Обработки.БыстрыйПереносРегистров.ВыгрузитьРегистрыФоном(
		МассивИмён, Папка, РазмерПорции, ЧислоПотоков, Сжатие, ФорматДанных, НачалоПериода, КонецПериода);
КонецПроцедуры

Процедура ЗагрузитьВсё(Папка, ОчищатьПередЗагрузкой, ЧислоПотоков, ПропускПриСовпадении) Экспорт
	Обработки.БыстрыйПереносРегистров.ЗагрузитьРегистрыФоном(
		Папка, ОчищатьПередЗагрузкой, ЧислоПотоков, ПропускПриСовпадении);
КонецПроцедуры

#КонецОбласти
