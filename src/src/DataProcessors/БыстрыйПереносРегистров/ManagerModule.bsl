#Область ПрограммныйИнтерфейс

// ── ТОЧКА РАСШИРЕНИЯ: ТРАНСПОРТ ЧАНКОВ ──────────────────────────────────────────
// Перенос абстрагирован как «выгрузка ПРОИЗВОДИТ чанки → транспорт → загрузка ПОТРЕБЛЯЕТ чанки».
// Транспорт = файлы (порции .bin + manifest.json в папке обмена) и сидит ТОЛЬКО в перечисленных
// функциях; движок чанкования, замещения по регистратору и параллелизма их не касается. Чтобы
// пустить перенос через RabbitMQ (или иную шину), организация подменяет ТОЛЬКО эти функции
// (найти все: поиск по «ТОЧКА РАСШИРЕНИЯ»):
//   выход, чанк     — ЗаписатьПорцию / ЗаписатьПорциюПотока  → publish сообщения
//   выход, манифест — ЗаписатьМанифест                       → стартовое сообщение / свойства
//   вход,  манифест — ПрочитатьМанифест                      → прочитать манифест из очереди
//   вход,  чанк     — ПрочитатьЧанк(...) в загрузке            → consume + ack (формат по расширению файла)
// Маппинг на RabbitMQ: чанк = тело сообщения (бинарь, тот же deflate из «Сжатия»);
//   routing key = имя регистра; durable queue + publisher confirms; ack после записи набора
//   (= встроенная идемпотентность/resume); prefetch = ЧислоПотоков (тот же параллелизм).
// Сам AMQP-коннектор пишет организация (внешняя компонента / готовый RMQ-коннектор) — здесь только шов.
// ───────────────────────────────────────────────────────────────────────────────

// Быстрая выгрузка регистров в папку: порции бинарных ХранилищЗначений + manifest.json.
// МассивИмён    - массив строк с именами регистров (РС/РН/РБ).
// ЧислоПотоков  - >1 включает ПАРАЛЛЕЛЬНУЮ выгрузку для толстых НЕЗАВИСИМЫХ РС
//                 (разбивка по числовому/датному полю, по фоновому заданию на диапазон).
//                 Мелкие РС, РС без числового/датного поля, подчинённые РН/РБ - всегда
//                 последовательно (мелкие отдаются мгновенно, дробить незачем).
// Сжатие        - 0 = писать ТЗ напрямую (быстрее всего, для локального NVMe);
//                 1..9 = обернуть в ХранилищеЗначения с deflate (меньше размер ценой CPU,
//                 на реальных данных ~x2-4; чтение почти бесплатно). Загрузка распознаёт
//                 сжатие автоматически (по типу значения), флаг при загрузке не нужен.
// ФорматДанных  - 0 = бинарные чанки (.bin, быстро); 1 = JSON (.json, «немагический» режим:
//                 портативно, переживает смену версии платформы/метаданных ценой размера/скорости,
//                 выгрузка в 1 поток). Загрузка распознаёт формат по расширению файла, флаг не нужен.
// НачалоПериода / КонецПериода - отбор по полю Период при выгрузке (обе или одна граница;
//                 пустая дата = без границы). Работает для РН/РБ и ПЕРИОДИЧЕСКИХ РС; для регистров
//                 без поля Период отбор игнорируется (об этом пишется в лог). Отбор фиксируется
//                 в манифесте, и загрузка такой частичной выгрузки с полной очисткой ЗАПРЕЩЕНА.
// Возвращает текстовый лог.
Функция ВыгрузитьРегистры(МассивИмён, Папка, РазмерПорции = 50000, ЧислоПотоков = 1, Сжатие = 0, ФорматДанных = 0,
		НачалоПериода = '00010101', КонецПериода = '00010101') Экспорт

	ПроверитьБезопасностьПапки(Папка);

	Лог = Новый Массив;
	ОписанияДляМанифеста = Новый Массив;

	Для Каждого Имя Из МассивИмён Цикл
		Опис = ОписаниеРегистра(Имя);
		Если Опис = Неопределено Тогда
			Лог.Добавить("[!] Регистр не найден: " + Имя);
			Продолжить;
		КонецЕсли;
		Элемент = ВыгрузитьОдинРегистр(Опис, Папка, РазмерПорции, ЧислоПотоков, Сжатие, ФорматДанных,
			НачалоПериода, КонецПериода);
		ОписанияДляМанифеста.Добавить(Элемент);
		СтрЛог = СтрШаблон("%1 ""%2"": строк %3, порций %4",
			Опис.Тип, Имя, Элемент.Строк, Элемент.Порции.Количество());
		// Видимость перекоса потоков (строк, реально попавших в каждый поток).
		Если Элемент.Свойство("СтрокПоПотокам") Тогда
			Части = Новый Массив;
			Для Каждого Ч Из Элемент.СтрокПоПотокам Цикл
				Части.Добавить(Формат(Ч, "ЧГ="));
			КонецЦикла;
			СтрЛог = СтрЛог + " | строк/поток: " + СтрСоединить(Части, " / ");
		КонецЕсли;
		Если Элемент.Свойство("ОтборПрименён") Тогда
			СтрЛог = СтрЛог + ?(Элемент.ОтборПрименён,
				" | отбор по периоду", " | отбор ПРОИГНОРИРОВАН (регистр без поля Период)");
		КонецЕсли;
		Лог.Добавить(СтрЛог);
	КонецЦикла;

	ЗаписатьМанифест(Папка, ОписанияДляМанифеста, Сжатие, ФорматДанных, НачалоПериода, КонецПериода);
	Лог.Добавить("Манифест записан: " + СоединитьПуть(Папка, "manifest.json"));
	Возврат СтрСоединить(Лог, Символы.ПС);

КонецФункции

// Быстрая загрузка регистров из папки (по manifest.json).
// ОчищатьПередЗагрузкой - полная перезаливка (срез): регистр очищается перед записью.
// ЧислоПотоков        - >1 включает ПАРАЛЛЕЛЬНУЮ загрузку независимых РС (порции раскидываются
//                       по фоновым заданиям). На файловой ИБ запись сериализуется блокировкой,
//                       поэтому выигрыш скромный; на клиент-серверной - реальный.
// ПропускПриСовпадении - если в приёмнике уже столько же строк, сколько в манифесте, регистр
//                       пропускается (шаг перезаливки не выполняется) - идемпотентность/экономия.
// Возвращает текстовый лог.
Функция ЗагрузитьРегистры(Папка, ОчищатьПередЗагрузкой = Истина, ЧислоПотоков = 1, ПропускПриСовпадении = Ложь) Экспорт

	ПроверитьБезопасностьПапки(Папка);

	Лог = Новый Массив;
	Манифест = ПрочитатьМанифест(Папка);
	Если Манифест = Неопределено Тогда
		Возврат "Не найден manifest.json в папке: " + Папка;
	КонецЕсли;

	// ЗАР: защита от потери данных на ЧАСТИЧНОЙ выгрузке. Если в манифесте зафиксирован отбор
	// по периоду, полная очистка приёмника заменила бы ВЕСЬ регистр куском периода — данные вне
	// периода погибли бы молча. Поэтому очищающая загрузка такой папки запрещается на входе:
	// грузить частичную выгрузку можно только режимом «Дозапись» (для РН/РБ замещение
	// по регистратору идемпотентно; для независимых РС возможны дубли — думает оператор).
	Если ОчищатьПередЗагрузкой И Манифест["Отбор"] <> Неопределено Тогда
		ВызватьИсключение "В манифесте зафиксирован отбор по периоду (частичная выгрузка)."
			+ " Полная очистка приёмника уничтожила бы данные вне периода."
			+ " Используйте режим «Дозапись (без очистки)».";
	КонецЕсли;

	Для Каждого ЭлРег Из Манифест["Регистры"] Цикл
		Имя = ЭлРег["Имя"];
		Опис = ОписаниеРегистра(Имя);
		Если Опис = Неопределено Тогда
			Лог.Добавить("[!] Регистр не найден в приёмнике: " + Имя);
			Продолжить;
		КонецЕсли;
		Если ПропускПриСовпадении И КоличествоВРегистре(Опис) = ЭлРег["Строк"] Тогда
			Лог.Добавить(СтрШаблон("%1 ""%2"": пропущено (количество совпадает: %3)",
				Опис.Тип, Имя, Формат(ЭлРег["Строк"], "ЧГ=")));
			Продолжить;
		КонецЕсли;
		Загружено = ЗагрузитьОдинРегистр(Папка, ЭлРег, Опис, ОчищатьПередЗагрузкой, ЧислоПотоков);
		Лог.Добавить(СтрШаблон("%1 ""%2"": загружено строк %3", Опис.Тип, Имя, Загружено));
	КонецЦикла;

	Возврат СтрСоединить(Лог, Символы.ПС);

КонецФункции

// Лёгкий предпросмотр для UI: имена регистров из manifest.json (или Неопределено, если манифеста нет).
// Только чтение, без транзакций обмена — безопасно вызывать до подтверждения загрузки.
Функция РегистрыМанифеста(Папка) Экспорт
	Манифест = ПрочитатьМанифест(Папка);
	Если Манифест = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Имена = Новый Массив;
	Для Каждого ЭлРег Из Манифест["Регистры"] Цикл
		Имена.Добавить(ЭлРег["Имя"]);
	КонецЦикла;
	Возврат Имена;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Определяет вид регистра, его подчинение и менеджер по имени.
Функция ОписаниеРегистра(ИмяРегистра)

	Если Метаданные.РегистрыСведений.Найти(ИмяРегистра) <> Неопределено Тогда
		МетаРегистра = Метаданные.РегистрыСведений[ИмяРегистра];
		Подчинение = ?(МетаРегистра.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору,
			"Регистратор", "Независимый");
		Возврат Новый Структура("Имя, Тип, ПолноеИмя, Подчинение, Менеджер, МетаОбъект",
			ИмяРегистра, "РегистрСведений", "РегистрСведений." + ИмяРегистра, Подчинение, РегистрыСведений[ИмяРегистра], МетаРегистра);

	ИначеЕсли Метаданные.РегистрыНакопления.Найти(ИмяРегистра) <> Неопределено Тогда
		Возврат Новый Структура("Имя, Тип, ПолноеИмя, Подчинение, Менеджер, МетаОбъект",
			ИмяРегистра, "РегистрНакопления", "РегистрНакопления." + ИмяРегистра, "Регистратор", РегистрыНакопления[ИмяРегистра], Метаданные.РегистрыНакопления[ИмяРегистра]);

	ИначеЕсли Метаданные.РегистрыБухгалтерии.Найти(ИмяРегистра) <> Неопределено Тогда
		Возврат Новый Структура("Имя, Тип, ПолноеИмя, Подчинение, Менеджер, МетаОбъект",
			ИмяРегистра, "РегистрБухгалтерии", "РегистрБухгалтерии." + ИмяРегистра, "Регистратор", РегистрыБухгалтерии[ИмяРегистра], Метаданные.РегистрыБухгалтерии[ИмяРегистра]);
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

// Диспетчер: параллельная выгрузка только для толстого независимого РС с полем разбиения,
// иначе - последовательная (как было). Мелочь и подчинённые РН/РБ идут последовательно.
Функция ВыгрузитьОдинРегистр(Опис, Папка, РазмерПорции, ЧислоПотоков = 1, Сжатие = 0, ФорматДанных = 0,
		НачалоПериода = '00010101', КонецПериода = '00010101')

	ОтборЗапрошен = ЕстьОтборПериода(НачалоПериода, КонецПериода);
	ОтборАктивен = ОтборЗапрошен И РегистрСПериодом(Опис);

	// JSON выгружается в 1 поток (портативность, не скорость); параллель — только для бинаря.
	// ЗАР: отбор по периоду тоже идёт последовательно. Совмещение отбора с MIN/MAX-сплитом
	// требует протянуть условие в 3 запроса (границы, счёт, воркер) ради редкого сценария:
	// отбор по периоду — это РН/РБ, а они и так последовательные. Не усложняем.
	Если ЧислоПотоков > 1 И Опис.Подчинение = "Независимый" И ФорматДанных = 0 И НЕ ОтборАктивен Тогда
		ПолеРазбиения = ПолеДляРазбиения(Опис);
		Если ПолеРазбиения <> Неопределено Тогда
			Возврат ВыгрузитьПараллельно(Опис, Папка, РазмерПорции, ЧислоПотоков, ПолеРазбиения, Сжатие);
		КонецЕсли;
	КонецЕсли;

	Элемент = ВыгрузитьПоследовательно(Опис, Папка, РазмерПорции, Сжатие, ФорматДанных,
		?(ОтборАктивен, НачалоПериода, '00010101'), ?(ОтборАктивен, КонецПериода, '00010101'));
	Если ОтборЗапрошен Тогда
		Элемент.Вставить("ОтборПрименён", ОтборАктивен);
	КонецЕсли;
	Возврат Элемент;

КонецФункции

Функция ВыгрузитьПоследовательно(Опис, Папка, РазмерПорции, Сжатие = 0, ФорматДанных = 0,
		НачалоПериода = '00010101', КонецПериода = '00010101')

	ЭтоПодчинённый = (Опис.Подчинение = "Регистратор");

	ТекстЗапроса = "ВЫБРАТЬ * ИЗ " + Опис.ПолноеИмя + " КАК Т";
	УсловиеОтбора = УсловиеПериода(НачалоПериода, КонецПериода);
	Если НЕ ПустаяСтрока(УсловиеОтбора) Тогда
		ТекстЗапроса = ТекстЗапроса + " ГДЕ " + УсловиеОтбора;
	КонецЕсли;
	// ЗАР: целостность данных подчинённых регистров (РН/РБ/РС) при выгрузке порциями.
	// В отличие от независимых РС (где дозапись Записать(Ложь) безопасна), подчинённые наборы пишутся
	// с ЗАМЕЩЕНИЕМ по регистратору (установка Отбор.Регистратор + Записать()). Дробление движений одного
	// регистратора между порциями => ПОТЕРЯ данных: следующая порция затрёт записанную предыдущей.
	// Поэтому выборка строго упорядочена ПО Регистратору, а граница порции сдвигается до СМЕНЫ регистратора ->
	// движения каждого документа гарантированно умещаются в одной порции (не трогать без понимания этого).
	Если ЭтоПодчинённый Тогда
		ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО Т.Регистратор";
	КонецЕсли;
	Запрос = Новый Запрос(ТекстЗапроса);
	Если НачалоПериода <> '00010101' Тогда
		Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	КонецЕсли;
	Если КонецПериода <> '00010101' Тогда
		Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	КонецЕсли;
	Результат = Запрос.Выполнить();

	// Шаблон ТЗ по колонкам результата (поля = поля записи регистра, маппинг по имени).
	ТаблицаПорции = Новый ТаблицаЗначений;
	Для Каждого Колонка Из Результат.Колонки Цикл
		ТаблицаПорции.Колонки.Добавить(Колонка.Имя, Колонка.ТипЗначения);
	КонецЦикла;

	МассивПорций = Новый Массив;
	ВсегоСтрок = 0;
	НомерПорции = 0;
	ПредыдущийРегистратор = Неопределено;

	// ЗАР: порционность (chunking). Не копим весь регистр в одну ТЗ - иначе RAM в потолок.
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл

		// Подчинённый: режем ПЕРЕД строкой нового регистратора, когда порция уже набрала лимит
		// (регистратор крупнее лимита -> просто увеличенная, но ЦЕЛАЯ порция).
		Если ЭтоПодчинённый Тогда
			Если Выборка.Регистратор <> ПредыдущийРегистратор И ТаблицаПорции.Количество() >= РазмерПорции Тогда
				МассивПорций.Добавить(ЗаписатьПорцию(Папка, Опис.Имя, НомерПорции, ТаблицаПорции, Сжатие, ФорматДанных));
				НомерПорции = НомерПорции + 1;
				ТаблицаПорции.Очистить();
				ЗаписатьПрогресс(Папка, "выгрузка_" + Опис.Имя, ВсегоСтрок);
			КонецЕсли;
			ПредыдущийРегистратор = Выборка.Регистратор;
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(ТаблицаПорции.Добавить(), Выборка);
		ВсегоСтрок = ВсегоСтрок + 1;

		// Независимый: дозапись безопасна, режем строго по лимиту строк.
		Если Не ЭтоПодчинённый И ТаблицаПорции.Количество() >= РазмерПорции Тогда
			МассивПорций.Добавить(ЗаписатьПорцию(Папка, Опис.Имя, НомерПорции, ТаблицаПорции, Сжатие, ФорматДанных));
			НомерПорции = НомерПорции + 1;
			ТаблицаПорции.Очистить();
			ЗаписатьПрогресс(Папка, "выгрузка_" + Опис.Имя, ВсегоСтрок);
		КонецЕсли;
	КонецЦикла;
	Если ТаблицаПорции.Количество() > 0 Тогда
		МассивПорций.Добавить(ЗаписатьПорцию(Папка, Опис.Имя, НомерПорции, ТаблицаПорции, Сжатие, ФорматДанных));
	КонецЕсли;
	ЗаписатьПрогресс(Папка, "выгрузка_" + Опис.Имя, ВсегоСтрок);

	Элемент = Новый Структура;
	Элемент.Вставить("Имя", Опис.Имя);
	Элемент.Вставить("Тип", Опис.Тип);
	Элемент.Вставить("Подчинение", Опис.Подчинение);
	Элемент.Вставить("Строк", ВсегоСтрок);
	Элемент.Вставить("Порции", МассивПорций);
	Возврат Элемент;

КонецФункции

// ТОЧКА РАСШИРЕНИЯ — транспорт (выход, чанк): сейчас файл порции; RMQ → publish сообщения. См. шапку модуля.
Функция ЗаписатьПорцию(Папка, ИмяРегистра, НомерПорции, ТаблицаПорции, Сжатие = 0, ФорматДанных = 0)

	ИмяФайла = ИмяРегистра + "_" + ДополнитьНулями(НомерПорции + 1, 4) + РасширениеЧанка(ФорматДанных);
	// ЗАР: транспорт - не один гигафайл, а файл на порцию. Бинарь: ЗначениеВФайл (быстро/компактно,
	// Сжатие>0 -> deflate в ХранилищеЗначения). JSON: СериализаторXDTO (портативно, см. ЗаписатьЧанк).
	ЗаписатьЧанк(СоединитьПуть(Папка, ИмяФайла), ТаблицаПорции, Сжатие, ФорматДанных);
	Возврат ИмяФайла;

КонецФункции

// ТЗ напрямую (Сжатие=0) или обёрнутую в ХранилищеЗначения с deflate-уровнем Сжатие (1..9).
Функция УпакованноеЗначение(Значение, Сжатие)
	Если Сжатие > 0 Тогда
		Возврат Новый ХранилищеЗначения(Значение, Новый СжатиеДанных(Сжатие));
	КонецЕсли;
	Возврат Значение;
КонецФункции

// Разворачивает значение из файла: ХранилищеЗначения -> исходная ТЗ, иначе как есть.
// Распознаём по типу (runtime) - не зависим от манифеста, future-proof.
Функция РазвёрнутоеЗначение(Значение)
	Если ТипЗнч(Значение) = Тип("ХранилищеЗначения") Тогда
		Возврат Значение.Получить();
	КонецЕсли;
	Возврат Значение;
КонецФункции

Функция РасширениеЧанка(ФорматДанных)
	Возврат ?(ФорматДанных = 1, ".json", ".bin");
КонецФункции

// Запись одного чанка. Бинарь (Формат=0): ЗначениеВФайл нативным форматом (+ опц. deflate).
// JSON (Формат=1) — «немагический режим для магглов»: СериализаторXDTO.ЗаписатьJSON. Читаемо любым
// инструментом и переживает смену версии платформы/метаданных (ценой размера и скорости).
Процедура ЗаписатьЧанк(Путь, ТаблицаПорции, Сжатие, ФорматДанных)
	Если ФорматДанных = 1 Тогда
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.ОткрытьФайл(Путь);
		// ЗАР: НазначениеТипаXML.Явное обязательно - без него сериализатор не пишет "#type" корня,
		// и ПрочитатьJSON падает «Ошибка преобразования данных XDTO ... anyType» (тип не восстановить).
		СериализаторXDTO.ЗаписатьJSON(ЗаписьJSON, ТаблицаПорции, НазначениеТипаXML.Явное);
		ЗаписьJSON.Закрыть();
	Иначе
		ЗначениеВФайл(Путь, УпакованноеЗначение(ТаблицаПорции, Сжатие));
	КонецЕсли;
КонецПроцедуры

// Чтение одного чанка. Формат распознаётся ПО РАСШИРЕНИЮ файла (самоописываемо — флаг в загрузку не тянем):
// .json -> СериализаторXDTO.ПрочитатьJSON, иначе -> ЗначениеИзФайла (+ авто-распаковка ХранилищаЗначения).
Функция ПрочитатьЧанк(Папка, ИмяПорции)
	Путь = СоединитьПуть(Папка, ИмяПорции);
	Если ВРег(Прав(ИмяПорции, 5)) = ".JSON" Тогда
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.ОткрытьФайл(Путь);
		ТаблицаПорции = СериализаторXDTO.ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Возврат ТаблицаПорции;
	КонецЕсли;
	Возврат РазвёрнутоеЗначение(ЗначениеИзФайла(Путь));
КонецФункции

// Fail-fast валидация источника до очистки приёмника: все файлы порций регистра существуют,
// первая порция реально читается (формат/сериализация). Бросает исключение с понятным текстом.
Процедура ПроверитьПорцииПередЗагрузкой(Папка, ЭлРег)
	Для Каждого ИмяПорции Из ЭлРег["Порции"] Цикл
		Файл = Новый Файл(СоединитьПуть(Папка, ИмяПорции));
		Если НЕ Файл.Существует() Тогда
			ВызватьИсключение СтрШаблон("Порция ""%1"" из манифеста не найдена в папке обмена — загрузка регистра ""%2"" отменена (приёмник не тронут).",
				ИмяПорции, ЭлРег["Имя"]);
		КонецЕсли;
	КонецЦикла;
	Если ЭлРег["Порции"].Количество() > 0 Тогда
		Попытка
			ПрочитатьЧанк(Папка, ЭлРег["Порции"][0]);
		Исключение
			ВызватьИсключение СтрШаблон("Порция ""%1"" не читается (битый файл или несовместимый формат) — загрузка регистра ""%2"" отменена (приёмник не тронут): %3",
				ЭлРег["Порции"][0], ЭлРег["Имя"], КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

// Имя числового/датного измерения или ресурса РС для разбиения на диапазоны (или Неопределено).
Функция ПолеДляРазбиения(Опис)

	Для Каждого Измерение Из Опис.МетаОбъект.Измерения Цикл
		Если ТипЧисловойИлиДата(Измерение.Тип) Тогда
			Возврат Измерение.Имя;
		КонецЕсли;
	КонецЦикла;
	Для Каждого Ресурс Из Опис.МетаОбъект.Ресурсы Цикл
		Если ТипЧисловойИлиДата(Ресурс.Тип) Тогда
			Возврат Ресурс.Имя;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;

КонецФункции

Функция ТипЧисловойИлиДата(ОписаниеТипов)
	Возврат ОписаниеТипов.СодержитТип(Тип("Число")) ИЛИ ОписаниеТипов.СодержитТип(Тип("Дата"));
КонецФункции

// Параллельная выгрузка независимого РС: разбиваем [Мин; Макс] поля на ЧислоПотоков
// полуоткрытых диапазонов, на каждый - фоновое задание со своими файлами-порциями.
Функция ВыгрузитьПараллельно(Опис, Папка, РазмерПорции, ЧислоПотоков, Поле, Сжатие = 0)

	Запрос = Новый Запрос("ВЫБРАТЬ МИНИМУМ(Т." + Поле + ") КАК Мин, МАКСИМУМ(Т." + Поле + ") КАК Макс,
		|КОЛИЧЕСТВО(*) КАК Кол ИЗ " + Опис.ПолноеИмя + " КАК Т");
	Гр = Запрос.Выполнить().Выбрать();
	Гр.Следующий();

	// Дробить незачем: пусто, мелочь (<= одной порции) или все значения поля одинаковы.
	Если Гр.Кол = 0 ИЛИ Гр.Кол <= РазмерПорции ИЛИ Гр.Мин = Гр.Макс Тогда
		Возврат ВыгрузитьПоследовательно(Опис, Папка, РазмерПорции, Сжатие);
	КонецЕсли;

	// Чистим прежние параллельные файлы именно этого регистра (свой неймспейс "<имя>_T...").
	Для Каждого Файл Из НайтиФайлы(Папка, Опис.Имя + "_T*.bin") Цикл
		Если Файл.ЭтоФайл() Тогда
			УдалитьФайлы(Файл.ПолноеИмя);
		КонецЕсли;
	КонецЦикла;

	// Равные по ШИРИНЕ диапазоны [Мин;Макс] (быстро, без доп. сортировки/прохода). Реальное число строк
	// в каждом потоке считаем дешёвыми агрегатными КОЛИЧЕСТВО (без сортировки; на индексированном поле -
	// счёт по индексу) -> перекос виден в логе, а параллелизм не страдает.
	// ЗАР: гистограммная балансировка (идея v3, сознательно НЕ реализована). Точные квантили через
	// УПОРЯДОЧИТЬ ПО уже пробовали - полный проход с сортировкой убил параллелизм (x1.70 -> x1.06),
	// откатили. Дешёвая альтернатива, если лог "строк/поток" покажет перекос НА СЕРВЕРНОЙ СУБД:
	//   ВЫБРАТЬ ГОД(Т.Период) КАК Год, КОЛИЧЕСТВО(*) КАК Строк
	//   ИЗ <ПолноеИмя> КАК Т СГРУППИРОВАТЬ ПО ГОД(Т.Период)
	// - лёгкий индексный агрегат даёт ВЕСА диапазонов; резать потоки по равному ВЕСУ строк,
	// а не по равной ширине. Внедрять по факту замера, не спекулятивно (наш принцип).
	Диапазон = Гр.Макс - Гр.Мин;
	СтрокПоПотокам = Новый Массив;
	Задания = Новый Массив;
	Для Поток = 0 По ЧислоПотоков - 1 Цикл
		Лево = Гр.Мин + Диапазон * Поток / ЧислоПотоков;
		Право = Гр.Мин + Диапазон * (Поток + 1) / ЧислоПотоков;
		Последний = (Поток = ЧислоПотоков - 1);
		СтрокПоПотокам.Добавить(КоличествоВДиапазоне(Опис.ПолноеИмя, Поле, Лево, Право, Последний));

		Парам = Новый Массив;
		Парам.Добавить(Опис.ПолноеИмя);
		Парам.Добавить(Опис.Имя);
		Парам.Добавить(Папка);
		Парам.Добавить(Поле);
		Парам.Добавить(Лево);
		Парам.Добавить(Право);
		Парам.Добавить(Последний);
		Парам.Добавить(Поток + 1);
		Парам.Добавить(РазмерПорции);
		Парам.Добавить(Сжатие);
		Задания.Добавить(ЗапуститьФоновоеЗадание("ПереносРегистровФон.ВыгрузитьДиапазон", Парам,
			"Выгрузка " + Опис.Имя + " поток " + Строка(Поток + 1) + "/" + Строка(ЧислоПотоков)));
	КонецЦикла;

	Для Каждого Задание Из Задания Цикл
		Задание.ОжидатьЗавершенияВыполнения();
	КонецЦикла;

	// Имена порций собираем с диска - что задания реально записали.
	МассивПорций = Новый Массив;
	Для Каждого Файл Из НайтиФайлы(Папка, Опис.Имя + "_T*.bin") Цикл
		Если Файл.ЭтоФайл() Тогда
			МассивПорций.Добавить(Файл.Имя);
		КонецЕсли;
	КонецЦикла;

	Элемент = Новый Структура;
	Элемент.Вставить("Имя", Опис.Имя);
	Элемент.Вставить("Тип", Опис.Тип);
	Элемент.Вставить("Подчинение", Опис.Подчинение);
	Элемент.Вставить("Строк", Гр.Кол);
	Элемент.Вставить("Порции", МассивПорций);
	Элемент.Вставить("СтрокПоПотокам", СтрокПоПотокам); // распределение строк по потокам (видимость перекоса)
	Возврат Элемент;

КонецФункции

// Выгрузка одного диапазона поля [Лево; Право) (последний поток - без верхней границы).
// Экспорт - вызывается фоновым заданием. Пишет свои файлы "<имя>_T<поток>_<порция>.bin".
Процедура ВыгрузитьДиапазонРегистраФон(ПолноеИмя, ИмяРегистра, Папка, Поле, Лево, Право, Последний, НомерПотока, РазмерПорции, Сжатие = 0) Экспорт

	ТекстЗапроса = "ВЫБРАТЬ * ИЗ " + ПолноеИмя + " КАК Т ГДЕ Т." + Поле + " >= &Лево";
	Если НЕ Последний Тогда
		ТекстЗапроса = ТекстЗапроса + " И Т." + Поле + " < &Право";
	КонецЕсли;
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Лево", Лево);
	Если НЕ Последний Тогда
		Запрос.УстановитьПараметр("Право", Право);
	КонецЕсли;
	Результат = Запрос.Выполнить();

	ТаблицаПорции = Новый ТаблицаЗначений;
	Для Каждого Колонка Из Результат.Колонки Цикл
		ТаблицаПорции.Колонки.Добавить(Колонка.Имя, Колонка.ТипЗначения);
	КонецЦикла;

	НомерПорции = 0;
	СтрокПотока = 0;
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаПорции.Добавить(), Выборка);
		СтрокПотока = СтрокПотока + 1;
		Если ТаблицаПорции.Количество() >= РазмерПорции Тогда
			ЗаписатьПорциюПотока(Папка, ИмяРегистра, НомерПотока, НомерПорции, ТаблицаПорции, Сжатие);
			НомерПорции = НомерПорции + 1;
			ТаблицаПорции.Очистить();
			ЗаписатьПрогресс(Папка, "выгрузка_" + ИмяРегистра + "_T" + Строка(НомерПотока), СтрокПотока);
		КонецЕсли;
	КонецЦикла;
	Если ТаблицаПорции.Количество() > 0 Тогда
		ЗаписатьПорциюПотока(Папка, ИмяРегистра, НомерПотока, НомерПорции, ТаблицаПорции, Сжатие);
	КонецЕсли;
	ЗаписатьПрогресс(Папка, "выгрузка_" + ИмяРегистра + "_T" + Строка(НомерПотока), СтрокПотока);

КонецПроцедуры

// ТОЧКА РАСШИРЕНИЯ — транспорт (выход, чанк, поток): сейчас файл порции потока; RMQ → publish. См. шапку.
Функция ЗаписатьПорциюПотока(Папка, ИмяРегистра, НомерПотока, НомерПорции, ТаблицаПорции, Сжатие = 0)
	ИмяФайла = ИмяРегистра + "_T" + Строка(НомерПотока) + "_" + ДополнитьНулями(НомерПорции + 1, 4) + ".bin";
	ЗначениеВФайл(СоединитьПуть(Папка, ИмяФайла), УпакованноеЗначение(ТаблицаПорции, Сжатие));
	Возврат ИмяФайла;
КонецФункции

// Запуск фонового задания в режиме "с БСП и без".
// ИмяМетода - 2-частное имя экспортного метода НАШЕГО общего модуля-шима ("ПереносРегистровФон.X"),
//             т.к. фоновое задание не умеет целиться напрямую в модуль менеджера обработки.
// Параметры - массив реальных параметров метода-шима.
// Если в конфигурации есть БСП, маршрутизируем через её безопасную обёртку
// ОбщегоНазначения.ВыполнитьМетодКонфигурации (безопасный режим + профили безопасности) - так
// обработка ведёт себя по стандартам БСП в "боевых" конфигурациях. Иначе - вызываем шим напрямую.
Функция ЗапуститьФоновоеЗадание(ИмяМетода, Параметры, Наименование)

	Если ЕстьБСП() Тогда
		ПараметрыБСП = Новый Массив;
		ПараметрыБСП.Добавить(ИмяМетода);   // имя метода-шима общего модуля
		ПараметрыБСП.Добавить(Параметры);    // массив реальных параметров
		Возврат ФоновыеЗадания.Выполнить("ОбщегоНазначения.ВыполнитьМетодКонфигурации", ПараметрыБСП, , Наименование);
	КонецЕсли;

	Возврат ФоновыеЗадания.Выполнить(ИмяМетода, Параметры, , Наименование);

КонецФункции

// Признак установленной БСП (по наличию ключевого общего модуля ОбщегоНазначения).
Функция ЕстьБСП()
	Возврат Метаданные.ОбщиеМодули.Найти("ОбщегоНазначения") <> Неопределено;
КонецФункции

// Диспетчер: параллельная загрузка только для независимого РС с несколькими порциями,
// иначе - последовательная (как было). Подчинённые РН/РБ всегда последовательно.
Функция ЗагрузитьОдинРегистр(Папка, ЭлРег, Опис, Очищать, ЧислоПотоков = 1)

	// ЗАР: fail-fast ДО очистки. Очистка регистра при Очищать=Истина происходит раньше чтения чанков;
	// если источник нечитаем (файла нет / битый формат), падение ПОСЛЕ очистки = потеря данных приёмника.
	// Поэтому до любой очистки проверяем: все файлы порций существуют, первая порция реально читается.
	ПроверитьПорцииПередЗагрузкой(Папка, ЭлРег);

	Если ЧислоПотоков > 1 И Опис.Подчинение = "Независимый" И ЭлРег["Порции"].Количество() > 1 Тогда
		Возврат ЗагрузитьПараллельно(Папка, ЭлРег, Опис, Очищать, ЧислоПотоков);
	КонецЕсли;

	Возврат ЗагрузитьПоследовательно(Папка, ЭлРег, Опис, Очищать);

КонецФункции

Функция ЗагрузитьПоследовательно(Папка, ЭлРег, Опис, Очищать)

	Если Очищать Тогда
		ОчиститьРегистр(Опис);
		СброситьЗагруженные(Папка, Опис.Имя); // полная перезаливка -> сбрасываем прогресс докачки
	КонецЕсли;

	// Докачка: пропускаем порции, уже отмеченные загруженными (возобновление после обрыва).
	Загруженные = ПрочитатьЗагруженные(Папка, Опис.Имя);

	ВсегоЗагружено = 0;
	Для Каждого ИмяПорции Из ЭлРег["Порции"] Цикл
		Если Загруженные[ИмяПорции] = Истина Тогда
			Продолжить;
		КонецЕсли;
		ТаблицаПорции = ПрочитатьЧанк(Папка, ИмяПорции);
		Если ТаблицаПорции = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если Опис.Подчинение = "Независимый" Тогда
			ЗагрузитьПорциюНезависимый(Опис.Менеджер, ТаблицаПорции);
		Иначе
			ЗагрузитьПорциюПодчинённый(Опис.Менеджер, ТаблицаПорции);
		КонецЕсли;
		ВсегоЗагружено = ВсегоЗагружено + ТаблицаПорции.Количество();
		ОтметитьЗагружено(Папка, Опис.Имя, ИмяПорции); // фиксируем прогресс порции
		ЗаписатьПрогресс(Папка, "загрузка_" + Опис.Имя, ВсегоЗагружено);
	КонецЦикла;

	Возврат ВсегоЗагружено;

КонецФункции

// Параллельная загрузка независимого РС: очистка ОДИН раз, затем порции раскидываются
// по потокам round-robin, на каждый поток - фоновое задание с дозаписью своих порций.
// (Ключи разных порций не пересекаются; на файловой ИБ записи всё равно сериализуются блокировкой.)
Функция ЗагрузитьПараллельно(Папка, ЭлРег, Опис, Очищать, ЧислоПотоков)

	Если Очищать Тогда
		ОчиститьРегистр(Опис);
	КонецЕсли;

	Корзины = Новый Массив;
	Для Поток = 1 По ЧислоПотоков Цикл
		Корзины.Добавить(Новый Массив);
	КонецЦикла;
	Индекс = 0;
	Для Каждого ИмяПорции Из ЭлРег["Порции"] Цикл
		Корзины[Индекс % ЧислоПотоков].Добавить(ИмяПорции);
		Индекс = Индекс + 1;
	КонецЦикла;

	Задания = Новый Массив;
	Для Поток = 0 По ЧислоПотоков - 1 Цикл
		Если Корзины[Поток].Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Парам = Новый Массив;
		Парам.Добавить(Опис.Имя);
		Парам.Добавить(Папка);
		Парам.Добавить(Корзины[Поток]);
		Парам.Добавить(Поток + 1); // номер потока - для файла прогресса
		Задания.Добавить(ЗапуститьФоновоеЗадание("ПереносРегистровФон.ЗагрузитьПорции", Парам,
			"Загрузка " + Опис.Имя + " поток " + Строка(Поток + 1) + "/" + Строка(ЧислоПотоков)));
	КонецЦикла;

	Для Каждого Задание Из Задания Цикл
		Задание.ОжидатьЗавершенияВыполнения();
	КонецЦикла;

	Возврат КоличествоВРегистре(Опис);

КонецФункции

// Загрузка набора порций независимого РС (дозапись). Экспорт - вызывается фоновым заданием.
Процедура ЗагрузитьПорцииНезависимыйФон(ИмяРегистра, Папка, МассивФайлов, НомерПотока = 0) Экспорт

	Менеджер = РегистрыСведений[ИмяРегистра];
	СтрокПотока = 0;
	Для Каждого ИмяФайла Из МассивФайлов Цикл
		ТаблицаПорции = ПрочитатьЧанк(Папка, ИмяФайла);
		Если ТаблицаПорции = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗагрузитьПорциюНезависимый(Менеджер, ТаблицаПорции);
		СтрокПотока = СтрокПотока + ТаблицаПорции.Количество();
		ЗаписатьПрогресс(Папка, "загрузка_" + ИмяРегистра + "_T" + Строка(НомерПотока), СтрокПотока);
	КонецЦикла;

КонецПроцедуры

Функция КоличествоВРегистре(Опис)
	Запрос = Новый Запрос("ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Кол ИЗ " + Опис.ПолноеИмя + " КАК Т");
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Кол;
КонецФункции

Процедура ЗагрузитьПорциюНезависимый(Менеджер, ТаблицаПорции)

	НаборЗаписей = Менеджер.СоздатьНаборЗаписей();
	// ЗАР: ОбменДанными.Загрузка = Истина отключает проверки/события платформы (режим обмена).
	НаборЗаписей.ОбменДанными.Загрузка = Истина;
	// Магия: Загрузить(ТЗ) мапит колонки в поля СУБД и пишет массивом (batch insert).
	НаборЗаписей.Загрузить(ТаблицаПорции);
	// ЗАР: Записать(Ложь) = дозапись (не замещать). При полной перезаливке регистр уже очищен заранее.
	НаборЗаписей.Записать(Ложь);

КонецПроцедуры

Процедура ЗагрузитьПорциюПодчинённый(Менеджер, ТаблицаПорции)

	// ЗАР: подчинённый набор пишется ЗАМЕЩЕНИЕМ по регистратору (дозапись Записать(Ложь) платформа
	// для таких регистров в режиме обмена запрещает). После фикса выгрузки движения одного регистратора
	// гарантированно лежат подряд в ОДНОЙ порции -> идём одним ЛИНЕЙНЫМ проходом, накапливая набор и
	// сбрасывая его при смене регистратора. Без НайтиСтроки в цикле (была квадратичная сложность).
	ТаблицаРегистратора = ТаблицаПорции.СкопироватьКолонки();
	ТекущийРегистратор = Неопределено;
	ЕстьДанные = Ложь;

	Для Каждого Строка Из ТаблицаПорции Цикл
		Если ЕстьДанные И Строка.Регистратор <> ТекущийРегистратор Тогда
			ЗаписатьНаборРегистратора(Менеджер, ТекущийРегистратор, ТаблицаРегистратора);
			ТаблицаРегистратора.Очистить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ТаблицаРегистратора.Добавить(), Строка);
		ТекущийРегистратор = Строка.Регистратор;
		ЕстьДанные = Истина;
	КонецЦикла;
	Если ЕстьДанные Тогда
		ЗаписатьНаборРегистратора(Менеджер, ТекущийРегистратор, ТаблицаРегистратора);
	КонецЕсли;

КонецПроцедуры

// Запись одного набора движений регистратора с замещением (режим обмена).
Процедура ЗаписатьНаборРегистратора(Менеджер, Регистратор, ТаблицаРегистратора)
	НаборЗаписей = Менеджер.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Регистратор.Установить(Регистратор);
	НаборЗаписей.ОбменДанными.Загрузка = Истина;
	НаборЗаписей.Загрузить(ТаблицаРегистратора);
	НаборЗаписей.Записать();
КонецПроцедуры

Процедура ОчиститьРегистр(Опис)

	Если Опис.Подчинение = "Независимый" Тогда
		НаборЗаписей = Опис.Менеджер.СоздатьНаборЗаписей();
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Записать(); // пустой отбор + замещение = очистка всего регистра
	Иначе
		Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ Регистратор КАК Регистратор ИЗ " + Опис.ПолноеИмя + " КАК Т");
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписей = Опис.Менеджер.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

// ТОЧКА РАСШИРЕНИЯ — транспорт (выход, манифест): сейчас файл manifest.json; RMQ → стартовое сообщение. См. шапку.
Процедура ЗаписатьМанифест(Папка, ОписанияРегистров, Сжатие = 0, ФорматДанных = 0,
		НачалоПериода = '00010101', КонецПериода = '00010101')

	Манифест = Новый Структура;
	Манифест.Вставить("Версия", 1);
	Манифест.Вставить("Сжатие", Сжатие);
	Манифест.Вставить("Формат", ФорматДанных);
	// Отбор фиксируется в манифесте: приёмник обязан знать, что выгрузка ЧАСТИЧНАЯ
	// (полная очистка при загрузке такой папки запрещена - см. ЗагрузитьРегистры).
	Если ЕстьОтборПериода(НачалоПериода, КонецПериода) Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("НачалоПериода", XMLСтрока(НачалоПериода));
		Отбор.Вставить("КонецПериода", XMLСтрока(КонецПериода));
		Манифест.Вставить("Отбор", Отбор);
	КонецЕсли;
	Манифест.Вставить("Регистры", ОписанияРегистров);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(СоединитьПуть(Папка, "manifest.json"), , , Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб));
	ЗаписатьJSON(ЗаписьJSON, Манифест);
	ЗаписьJSON.Закрыть();

КонецПроцедуры

// ТОЧКА РАСШИРЕНИЯ — транспорт (вход, манифест): сейчас файл manifest.json; RMQ → чтение из очереди. См. шапку.
// Возвращает ВЕСЬ манифест (Соответствие: Версия/Сжатие/Формат/Отбор?/Регистры) или Неопределено.
Функция ПрочитатьМанифест(Папка)

	Файл = Новый Файл(СоединитьПуть(Папка, "manifest.json"));
	Если НЕ Файл.Существует() Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьФайл(СоединитьПуть(Папка, "manifest.json"));
	// ЗАР: читаем В СООТВЕТСТВИЕ (Истина), не в Структуру: у Структуры обращение по отсутствующему
	// ключу ("Отбор" есть не во всех манифестах) падает «Поле объекта не обнаружено»,
	// у Соответствия - возвращает Неопределено. Старые манифесты v1 читаются без ошибок.
	Манифест = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Возврат Манифест;

КонецФункции

// === Безопасность: валидация папки обмена (безопасный режим снят -> код пишет/читает от rphost). ===
// Базовый guard: запрет пустого/относительного пути, корня диска и системных каталогов.
Процедура ПроверитьБезопасностьПапки(Папка)

	П = СокрЛП(Папка);
	Если ПустаяСтрока(П) Тогда
		ВызватьИсключение "Папка обмена не задана.";
	КонецЕсли;

	Норм = СтрЗаменить(П, "/", "\");
	ЭтоАбсолютный = (СтрНайти(Норм, ":\") > 0) ИЛИ СтрНачинаетсяС(Норм, "\\");
	Если НЕ ЭтоАбсолютный Тогда
		ВызватьИсключение "Папка обмена должна быть абсолютным путём: " + П;
	КонецЕсли;

	// Корень диска целиком ("C:\") - запрет.
	Если СтрДлина(СтрЗаменить(Норм, "\", "")) <= 2 Тогда
		ВызватьИсключение "Папка обмена не может быть корнем диска: " + П;
	КонецЕсли;

	ВВерх = ВРег(Норм) + "\";
	Запрещённые = "\WINDOWS\,\SYSTEM32\,\PROGRAM FILES\,\PROGRAM FILES (X86)\,\PROGRAMDATA\MICROSOFT\,\BOOT\";
	Для Каждого Фрагмент Из СтрРазделить(Запрещённые, ",", Ложь) Цикл
		Если СтрНайти(ВВерх, Фрагмент) > 0 Тогда
			ВызватьИсключение "Запрещённый системный путь в папке обмена: " + П;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// === Видимость перекоса: число строк в диапазоне поля [Лево; Право) (последний - без верхней границы). ===
// Дешёвый агрегат КОЛИЧЕСТВО без сортировки (на индексированном измерении - счёт по индексу), чтобы показать
// реальное распределение строк по потокам в логе, НЕ нагружая параллельную выгрузку (диапазоны - равные по ширине).
Функция КоличествоВДиапазоне(ПолноеИмя, Поле, Лево, Право, Последний)

	ТекстЗапроса = "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК К ИЗ " + ПолноеИмя + " КАК Т ГДЕ Т." + Поле + " >= &Лево";
	Если НЕ Последний Тогда
		ТекстЗапроса = ТекстЗапроса + " И Т." + Поле + " < &Право";
	КонецЕсли;
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Лево", Лево);
	Если НЕ Последний Тогда
		Запрос.УстановитьПараметр("Право", Право);
	КонецЕсли;
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.К;

КонецФункции

// === Докачка: учёт загруженных порций для возобновления после обрыва (последовательная загрузка). ===
Функция ФайлЗагруженных(Папка, Имя)
	Возврат СоединитьПуть(Папка, "_загружено_" + Имя + ".txt");
КонецФункции

Функция ПрочитатьЗагруженные(Папка, Имя)
	Соот = Новый Соответствие;
	Путь = ФайлЗагруженных(Папка, Имя);
	Файл = Новый Файл(Путь);
	Если Файл.Существует() Тогда
		Чтение = Новый ЧтениеТекста(Путь, КодировкаТекста.UTF8);
		Стр = Чтение.ПрочитатьСтроку();
		Пока Стр <> Неопределено Цикл
			Если НЕ ПустаяСтрока(Стр) Тогда
				Соот.Вставить(СокрЛП(Стр), Истина);
			КонецЕсли;
			Стр = Чтение.ПрочитатьСтроку();
		КонецЦикла;
		Чтение.Закрыть();
	КонецЕсли;
	Возврат Соот;
КонецФункции

Процедура СброситьЗагруженные(Папка, Имя)
	Путь = ФайлЗагруженных(Папка, Имя);
	Файл = Новый Файл(Путь);
	Если Файл.Существует() Тогда
		УдалитьФайлы(Путь);
	КонецЕсли;
КонецПроцедуры

Процедура ОтметитьЗагружено(Папка, Имя, ИмяПорции)
	Запись = Новый ЗаписьТекста(ФайлЗагруженных(Папка, Имя), КодировкаТекста.UTF8, , Истина);
	Запись.ЗаписатьСтроку(ИмяПорции);
	Запись.Закрыть();
КонецПроцедуры

Функция СоединитьПуть(Папка, Имя)
	Разделитель = ?(Найти(Папка, "/") > 0, "/", "\");
	Если Прав(Папка, 1) = "\" ИЛИ Прав(Папка, 1) = "/" Тогда
		Возврат Папка + Имя;
	КонецЕсли;
	Возврат Папка + Разделитель + Имя;
КонецФункции

Функция ДополнитьНулями(Число, Длина)
	Стр = Строка(Число);
	Пока СтрДлина(Стр) < Длина Цикл
		Стр = "0" + Стр;
	КонецЦикла;
	Возврат Стр;
КонецФункции

// === Отбор по периоду при выгрузке ===

Функция ЕстьОтборПериода(НачалоПериода, КонецПериода)
	Возврат НачалоПериода <> '00010101' ИЛИ КонецПериода <> '00010101';
КонецФункции

// Есть ли у регистра поле Период: РН/РБ - всегда; РС - только периодические.
Функция РегистрСПериодом(Опис)
	Если Опис.Тип <> "РегистрСведений" Тогда
		Возврат Истина; // РН/РБ всегда с периодом
	КонецЕсли;
	// ЗАР: для РС проверяем пробным запросом, а не свойством метаданных - обращение к свойству
	// динамическое (компилятор не проверит), а "ВЫБРАТЬ ПЕРВЫЕ 0 Т.Период" ничего не читает
	// и надёжен по построению: скомпилировался - поле есть.
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 0 Т.Период ИЗ " + Опис.ПолноеИмя + " КАК Т");
	Попытка
		Запрос.Выполнить();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

// Текст условия по полю Период (без слова ГДЕ); пустая дата = граница не задана.
Функция УсловиеПериода(НачалоПериода, КонецПериода)
	Части = Новый Массив;
	Если НачалоПериода <> '00010101' Тогда
		Части.Добавить("Т.Период >= &НачалоПериода");
	КонецЕсли;
	Если КонецПериода <> '00010101' Тогда
		Части.Добавить("Т.Период <= &КонецПериода");
	КонецЕсли;
	Возврат СтрСоединить(Части, " И ");
КонецФункции

// === Живой прогресс: служебные файлы в папке обмена ===
// Схема: воркеры после каждого чанка перезаписывают свой "_прогресс_<метка>.json" ({"Строк": N}),
// главное фоновое задание пишет "_план.json" (общий объём) и "_итог.json" (статус/лог).
// Форма раз в 2 с суммирует прогресс-файлы и рисует индикатор (см. ПрогрессПереноса).

Процедура ЗаписатьПрогресс(Папка, Метка, Строк)
	Попытка
		Запись = Новый ЗаписьТекста(СоединитьПуть(Папка, "_прогресс_" + Метка + ".json"), КодировкаТекста.UTF8);
		Запись.Записать("{""Строк"": " + Формат(Строк, "ЧГ=") + "}");
		Запись.Закрыть();
	Исключение
		// Индикатор не важнее переноса: молча пропускаем, следующий чанк перезапишет.
	КонецПопытки;
КонецПроцедуры

Процедура УдалитьФайлыПоМаске(Папка, Маска)
	Для Каждого Файл Из НайтиФайлы(Папка, Маска) Цикл
		Если Файл.ЭтоФайл() Тогда
			УдалитьФайлы(Файл.ПолноеИмя);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ОчиститьФайлыПрогресса(Папка)
	УдалитьФайлыПоМаске(Папка, "_прогресс_*.json");
	УдалитьФайлыПоМаске(Папка, "_план.json");
	УдалитьФайлыПоМаске(Папка, "_итог.json");
КонецПроцедуры

Процедура ЗаписатьСлужебныйJSON(Папка, ИмяФайла, Данные)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(СоединитьПуть(Папка, ИмяФайла), , , Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб));
	ЗаписатьJSON(ЗаписьJSON, Данные);
	ЗаписьJSON.Закрыть();
КонецПроцедуры

Функция ПрочитатьСлужебныйJSON(Папка, ИмяФайла)
	Файл = Новый Файл(СоединитьПуть(Папка, ИмяФайла));
	Если НЕ Файл.Существует() Тогда
		Возврат Неопределено;
	КонецЕсли;
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьФайл(Файл.ПолноеИмя);
	Данные = ПрочитатьJSON(ЧтениеJSON, Истина); // в Соответствие (см. ЗАР в ПрочитатьМанифест)
	ЧтениеJSON.Закрыть();
	Возврат Данные;
КонецФункции

Процедура ЗаписатьИтог(Папка, Статус, Лог)
	Попытка
		ЗаписатьСлужебныйJSON(Папка, "_итог.json", Новый Структура("Статус, Лог", Статус, Лог));
	Исключение
		// Если и итог не пишется (папка недоступна) - состояние донесёт статус фонового задания.
	КонецПопытки;
КонецПроцедуры

// Общий объём предстоящей выгрузки (для процента): дешёвые COUNT по регистрам с учётом отбора.
Функция ПланВыгрузки(МассивИмён, НачалоПериода, КонецПериода)
	Всего = 0;
	Для Каждого Имя Из МассивИмён Цикл
		Опис = ОписаниеРегистра(Имя);
		Если Опис = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Условие = "";
		Если ЕстьОтборПериода(НачалоПериода, КонецПериода) И РегистрСПериодом(Опис) Тогда
			Условие = УсловиеПериода(НачалоПериода, КонецПериода);
		КонецЕсли;
		ТекстЗапроса = "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Кол ИЗ " + Опис.ПолноеИмя + " КАК Т"
			+ ?(ПустаяСтрока(Условие), "", " ГДЕ " + Условие);
		Запрос = Новый Запрос(ТекстЗапроса);
		Если НЕ ПустаяСтрока(Условие) И НачалоПериода <> '00010101' Тогда
			Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
		КонецЕсли;
		Если НЕ ПустаяСтрока(Условие) И КонецПериода <> '00010101' Тогда
			Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
		КонецЕсли;
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		Всего = Всего + Выборка.Кол;
	КонецЦикла;
	Возврат Всего;
КонецФункции

// === Фоновый перенос целиком (вызывается через шим ПереносРегистровФон) ===

// Полный цикл выгрузки фоновым заданием: чистит файлы прогресса, пишет _план.json,
// гонит ВыгрузитьРегистры, в конце - _итог.json и bpr_transfer.prom.
Процедура ВыгрузитьРегистрыФоном(МассивИмён, Папка, РазмерПорции, ЧислоПотоков, Сжатие, ФорматДанных,
		НачалоПериода = '00010101', КонецПериода = '00010101') Экспорт

	Старт = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Попытка
		ПроверитьБезопасностьПапки(Папка);
		ОчиститьФайлыПрогресса(Папка);
		Всего = ПланВыгрузки(МассивИмён, НачалоПериода, КонецПериода);
		ЗаписатьСлужебныйJSON(Папка, "_план.json", Новый Структура("Всего", Всего));
		Лог = ВыгрузитьРегистры(МассивИмён, Папка, РазмерПорции, ЧислоПотоков, Сжатие, ФорматДанных,
			НачалоПериода, КонецПериода);
		Мс = ТекущаяУниверсальнаяДатаВМиллисекундах() - Старт;
		ЗаписатьИтог(Папка, "OK", Лог);
		ЗаписатьПромМетрики(Папка, "dump", Всего, Мс, РазмерТранспорта(Папка), ЧислоПотоков, ФорматДанных);
	Исключение
		ЗаписатьИтог(Папка, "Ошибка", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение; // и статус задания должен стать аварийным
	КонецПопытки;

КонецПроцедуры

// Полный цикл загрузки фоновым заданием. Симметричен выгрузке; объём берётся из манифеста.
Процедура ЗагрузитьРегистрыФоном(Папка, ОчищатьПередЗагрузкой, ЧислоПотоков, ПропускПриСовпадении) Экспорт

	Старт = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Попытка
		ПроверитьБезопасностьПапки(Папка);
		ОчиститьФайлыПрогресса(Папка);
		Всего = 0;
		ФорматИсточника = 0;
		Манифест = ПрочитатьМанифест(Папка);
		Если Манифест <> Неопределено Тогда
			Для Каждого ЭлРег Из Манифест["Регистры"] Цикл
				Всего = Всего + ЭлРег["Строк"];
			КонецЦикла;
			Если Манифест["Формат"] <> Неопределено Тогда
				ФорматИсточника = Манифест["Формат"]; // для метки format в .prom
			КонецЕсли;
		КонецЕсли;
		ЗаписатьСлужебныйJSON(Папка, "_план.json", Новый Структура("Всего", Всего));
		Лог = ЗагрузитьРегистры(Папка, ОчищатьПередЗагрузкой, ЧислоПотоков, ПропускПриСовпадении);
		Мс = ТекущаяУниверсальнаяДатаВМиллисекундах() - Старт;
		ЗаписатьИтог(Папка, "OK", Лог);
		ЗаписатьПромМетрики(Папка, "load", Всего, Мс, РазмерТранспорта(Папка), ЧислоПотоков, ФорматИсточника);
	Исключение
		ЗаписатьИтог(Папка, "Ошибка", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// === API формы: запуск / прогресс / отмена фонового переноса ===

// Направление: "выгрузка" | "загрузка". Параметры - массив аргументов метода-шима.
// Возвращает строку УИД фонового задания.
Функция ЗапуститьПереносФоном(Направление, Параметры) Экспорт
	Метод = ?(Направление = "выгрузка", "ПереносРегистровФон.ВыгрузитьВсё", "ПереносРегистровФон.ЗагрузитьВсё");
	Задание = ЗапуститьФоновоеЗадание(Метод, Параметры, "Быстрый перенос: " + Направление);
	Возврат Строка(Задание.УникальныйИдентификатор);
КонецФункции

// Снимок прогресса для опроса из формы:
// Структура {Активно, Статус ("OK"/"Ошибка"/"Отменено"/""), Сделано, Всего, Лог}.
Функция ПрогрессПереноса(Папка, ИдЗадания) Экспорт

	Ответ = Новый Структура("Активно, Статус, Сделано, Всего, Лог", Ложь, "", 0, 0, "");

	Для Каждого Файл Из НайтиФайлы(Папка, "_прогресс_*.json") Цикл
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.ОткрытьФайл(Файл.ПолноеИмя);
			Данные = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			Ответ.Сделано = Ответ.Сделано + Данные["Строк"];
		Исключение
			// Файл мог быть в середине перезаписи - доберём следующим тиком.
		КонецПопытки;
	КонецЦикла;

	План = ПрочитатьСлужебныйJSON(Папка, "_план.json");
	Если План <> Неопределено Тогда
		Ответ.Всего = План["Всего"];
	КонецЕсли;

	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Новый УникальныйИдентификатор(ИдЗадания));
	Ответ.Активно = (Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно);
	Если Ответ.Активно Тогда
		Возврат Ответ;
	КонецЕсли;

	Итог = ПрочитатьСлужебныйJSON(Папка, "_итог.json");
	Если Итог <> Неопределено Тогда
		Ответ.Статус = Итог["Статус"];
		Ответ.Лог = Итог["Лог"];
	ИначеЕсли Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
		Ответ.Статус = "Отменено";
		Ответ.Лог = "Перенос отменён пользователем.";
	ИначеЕсли Задание <> Неопределено И Задание.ИнформацияОбОшибке <> Неопределено Тогда
		Ответ.Статус = "Ошибка";
		Ответ.Лог = КраткоеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
	Иначе
		Ответ.Статус = "Ошибка";
		Ответ.Лог = "Фоновое задание завершилось, не оставив итога (возможно, сервер перезапускался).";
	КонецЕсли;
	Возврат Ответ;

КонецФункции

// Отмена главного задания. Воркеры-диапазоны доработают текущий диапазон и завершатся сами -
// это безопасно (выгрузка только читает; недописанная папка перезапишется следующим прогоном).
Процедура ОтменитьПеренос(ИдЗадания) Экспорт
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Новый УникальныйИдентификатор(ИдЗадания));
	Если Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Задание.Отменить();
	КонецЕсли;
КонецПроцедуры

// === OpenMetrics (.prom) - для node_exporter textfile collector / Grafana ===

// Суммарный размер файлов транспорта (чанки + манифест); служебные "_*" не считаем.
Функция РазмерТранспорта(Папка)
	Всего = 0;
	Для Каждого Маска Из СтрРазделить("*.bin,*.json", ",") Цикл
		Для Каждого Файл Из НайтиФайлы(Папка, Маска) Цикл
			Если Файл.ЭтоФайл() И НЕ СтрНачинаетсяС(Файл.Имя, "_") Тогда
				Всего = Всего + Файл.Размер();
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Всего;
КонецФункции

// Метрики последнего прогона в bpr_transfer.prom (перезаписывается - textfile collector читает срез).
Процедура ЗаписатьПромМетрики(Папка, Направление, Строк, Мс, Байт, Потоки, ФорматДанных) Экспорт
	Метки = "{direction=""" + Направление + """,format=""" + ?(ФорматДанных = 1, "json", "bin") + """}";
	Секунд = Мс / 1000;
	Стр = Новый Массив;
	Стр.Добавить("# Быстрый перенос регистров: метрики последнего прогона");
	Стр.Добавить("# TYPE bpr_rows_total gauge");
	Стр.Добавить("bpr_rows_total" + Метки + " " + ПромЧисло(Строк, 0));
	Стр.Добавить("# TYPE bpr_seconds gauge");
	Стр.Добавить("bpr_seconds" + Метки + " " + ПромЧисло(Секунд, 3));
	Стр.Добавить("# TYPE bpr_rows_per_second gauge");
	Стр.Добавить("bpr_rows_per_second" + Метки + " " + ПромЧисло(?(Секунд > 0, Строк / Секунд, 0), 0));
	Стр.Добавить("# TYPE bpr_bytes_total gauge");
	Стр.Добавить("bpr_bytes_total" + Метки + " " + ПромЧисло(Байт, 0));
	Стр.Добавить("# TYPE bpr_threads gauge");
	Стр.Добавить("bpr_threads" + Метки + " " + ПромЧисло(Потоки, 0));
	ЗаписатьПромФайл(Папка, "bpr_transfer.prom", Стр);
КонецПроцедуры

// Запись .prom-файла из готовых строк (используется и харнессом бенчмарков).
Процедура ЗаписатьПромФайл(Папка, ИмяФайла, Строки) Экспорт
	Попытка
		Запись = Новый ЗаписьТекста(СоединитьПуть(Папка, ИмяФайла), КодировкаТекста.UTF8);
		Запись.Записать(СтрСоединить(Строки, Символы.ПС) + Символы.ПС);
		Запись.Закрыть();
	Исключение
		// Метрики не критичны.
	КонецПопытки;
КонецПроцедуры

// Число в формате Prometheus: точка-разделитель дроби, без группировки разрядов.
// ЧН=0 обязателен: Формат(0, ...) в 1С даёт пустую строку - метрика с пустым значением
// ломает парсер textfile collector.
Функция ПромЧисло(Значение, Дробных) Экспорт
	Возврат Формат(Значение, "ЧДЦ=" + Формат(Дробных, "ЧГ=; ЧН=0") + "; ЧРД=.; ЧГ=; ЧН=0");
КонецФункции

#КонецОбласти
