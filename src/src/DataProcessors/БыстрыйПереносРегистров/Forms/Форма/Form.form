      <items xsi:type="form:FormField">
        <name>Сжатие</name>
        <id>46</id>
        <title>
          <key>ru</key>
          <value>Сжатие (0=выкл, 1-9=deflate)</value>
        </title>
        <visible>true</visible>
        <enabled>true</enabled>
        <userVisible>
          <common>true</common>
        </userVisible>
        <dataPath xsi:type="form:DataPath">
          <segments>Сжатие</segments>
        </dataPath>
        <extendedTooltip>
          <name>СжатиеРасширеннаяПодсказка</name>
          <id>48</id>
          <title>
            <key>ru</key>
            <value>0 = без сжатия, ТЗ пишется напрямую (быстрее всего, для локального NVMe). 1-9 = deflate в ХранилищеЗначения: меньше размер ценой CPU при записи (на реальных данных ~x2-4; чтение почти бесплатно). Загрузка распознаёт сжатие автоматически.</value>
          </title>
          <type>Label</type>
          <autoMaxWidth>true</autoMaxWidth>
          <autoMaxHeight>true</autoMaxHeight>
          <extInfo xsi:type="form:LabelDecorationExtInfo">
            <horizontalAlign>Left</horizontalAlign>
          </extInfo>
        </extendedTooltip>
        <contextMenu>
