#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Заголовок = "Быстрый перенос регистров";
	// Разумные дефолты, чтобы поля не были пустыми/0 (и обойти баг ввода числовых полей веб-клиента).
	Если ПустаяСтрока(ПапкаОбмена) Тогда
		ПапкаОбмена = "D:\1CRoot\benchmen";
	КонецЕсли;
	Если ПустаяСтрока(РегистрТеста) Тогда
		РегистрТеста = НагрузочныйТест.ИмяСинтетическогоРегистра();
	КонецЕсли;
	Если РазмерПакета = 0 Тогда
		РазмерПакета = 50000;
	КонецЕсли;
	Если РазмерПорции = 0 Тогда
		РазмерПорции = 100000; // оптимум из теста подбора чанка (плоская зона 50k-200k)
	КонецЕсли;
	Если КоличествоСтрок = 0 Тогда
		КоличествоСтрок = 5000000; // объём по умолчанию для тестов
	КонецЕсли;
	Если ПотокиВыгрузки = 0 Тогда
		ПотокиВыгрузки = 4; // выгрузка (чтение) распараллеливается агрессивнее загрузки
	КонецЕсли;
	Если ПотокиЗагрузки = 0 Тогда
		ПотокиЗагрузки = 4; // загрузка (запись) консервативнее; профиль уточнит
	КонецЕсли;
	// Сжатие = 0 (прямой ЗначениеВФайл) по умолчанию.
	// Режим загрузки: 0 Полная перезаливка / 1 Перезаливка, пропуская совпадающие / 2 Дозапись поверх (дефолт 0).
	Элементы.РежимЗагрузки.СписокВыбора.Добавить(0, "Полная перезаливка");
	Элементы.РежимЗагрузки.СписокВыбора.Добавить(1, "Перезаливка, пропуская совпадающие");
	Элементы.РежимЗагрузки.СписокВыбора.Добавить(2, "Дозапись (без очистки)");
	// Формат чанков: 0 бинарный (.bin, быстро) / 1 JSON (.json, портативно). Дефолт 0.
	Элементы.ФорматДанных.СписокВыбора.Добавить(0, "Бинарный (.bin)");
	Элементы.ФорматДанных.СписокВыбора.Добавить(1, "JSON (портативный)");
	// Профиль среды (БД приёмника): пресет порции и раздельных потоков под СУБД.
	Элементы.ПрофильСреды.СписокВыбора.Добавить(0, "Файловая ИБ");
	Элементы.ПрофильСреды.СписокВыбора.Добавить(1, "MS SQL Server");
	Элементы.ПрофильСреды.СписокВыбора.Добавить(2, "PostgreSQL");
	Элементы.ПрофильСреды.СписокВыбора.Добавить(4, "Экстремальный режим");
	Элементы.ПрофильСреды.СписокВыбора.Добавить(3, "Вручную");
	// Режим разработчика по умолчанию выключен (влияет на видимость настроек и вкладки «Бенчмарк»).
	РежимРазработчика = Ложь;
	// Автоопределяем тип ИБ и применяем пресет (Вручную — настройки не трогаем). Видимость настроек — внутри ПрименитьПрофиль.
	ПрофильСреды = ОпределитьПрофильСреды();
	ПрименитьПрофиль();
	// Кнопки «Отменить» активны только пока идёт фоновый перенос.
	Элементы.ОтменаКнопкаВыгрузка.Доступность = Ложь;
	Элементы.ОтменаКнопкаЗагрузка.Доступность = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура ПапкаОбменаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	// Кросс-клиентно: в вебе нужен файловый агент (подключаем по запросу), в тонком/толстом - подключится сразу.
	НачатьПодключениеРасширенияРаботыСФайлами(
		Новый ОписаниеОповещения("ПапкаОбменаПослеПодключенияРасширения", ЭтотОбъект));
КонецПроцедуры

&НаКлиенте
Процедура ПапкаОбменаПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	Если НЕ Подключено Тогда
		ПоказатьПредупреждение(, "Для выбора папки нужно расширение работы с файлами (в веб-клиенте установить по запросу).");
		Возврат;
	КонецЕсли;
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите папку обмена";
	Если НЕ ПустаяСтрока(ПапкаОбмена) Тогда
		Диалог.Каталог = ПапкаОбмена;
	КонецЕсли;
	Диалог.Показать(Новый ОписаниеОповещения("ПапкаОбменаПослеВыбора", ЭтотОбъект));
КонецПроцедуры

&НаКлиенте
Процедура ПапкаОбменаПослеВыбора(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	Если ВыбранныеФайлы <> Неопределено И ВыбранныеФайлы.Количество() > 0 Тогда
		ПапкаОбмена = ВыбранныеФайлы[0];
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИменаРегистровНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	// Чек-лист всех регистров конфигурации (РС/РН/РБ); уже выбранные - помечены.
	Список = СписокРегистровДляВыбора();
	Список.ПоказатьОтметкуЭлементов(
		Новый ОписаниеОповещения("ИменаРегистровПослеВыбора", ЭтотОбъект),
		"Выберите регистры для переноса");
КонецПроцедуры

&НаКлиенте
Процедура ИменаРегистровПослеВыбора(Список, ДополнительныеПараметры) Экспорт
	Если Список = Неопределено Тогда
		Возврат; // отмена
	КонецЕсли;
	Выбранные = Новый Массив;
	Для Каждого Элемент Из Список Цикл
		Если Элемент.Пометка Тогда
			Выбранные.Добавить(Элемент.Значение);
		КонецЕсли;
	КонецЦикла;
	ИменаРегистров = СтрСоединить(Выбранные, ", "); // запятая надёжнее ПС для отображения/разбора в одностроке
КонецПроцедуры

&НаКлиенте
Процедура ПрофильСредыПриИзменении(Элемент)
	ПрименитьПрофиль(); // серверная процедура: пресет настроек + их видимость
КонецПроцедуры

&НаКлиенте
Процедура РежимРазработчикаПриИзменении(Элемент)
	ОбновитьВидимостьНастроек();
КонецПроцедуры

&НаКлиенте
Процедура НастройкаПриИзменении(Элемент)
	ПрофильСреды = 3; // ручная правка тюнинг-поля → профиль «Вручную» (лейбл не врёт)
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выгрузить(Команда)
	Если НЕ ПроверитьПередЗапуском(Истина) Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ПустаяСтрока(ИдЗадания) Тогда
		ПоказатьПредупреждение(, "Перенос уже выполняется. Дождитесь завершения или отмените.");
		Возврат;
	КонецЕсли;
	// Перенос идёт ФОНОВЫМ заданием: длинный синхронный вызов фризил веб-клиент и рвался
	// на больших объёмах. Форма лишь запускает задание и раз в 2 с опрашивает прогресс.
	Попытка
		ЗапуститьВыгрузкуНаСервере();
	Исключение
		ПоказатьПредупреждение(, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	НачатьНаблюдениеПрогресса();
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьПеренос(Команда)
	Если ПустаяСтрока(ИдЗадания) Тогда
		Возврат;
	КонецЕсли;
	ОтменитьПереносНаСервере();
	// Финал (статус «Отменено») дорисует очередной тик опроса.
КонецПроцедуры

&НаКлиенте
Процедура НачатьНаблюдениеПрогресса()
	Элементы.СтраницыГлавная.ТекущаяСтраница = Элементы.Отчет;
	ОбновитьДоступностьПереноса();
	ПодключитьОбработчикОжидания("ПрогрессТик", 2, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПрогрессТик() Экспорт
	Завершено = Ложь;
	Попытка
		Завершено = ПрогрессТикНаСервере();
	Исключение
		// Разовый сбой опроса (сервер перезапускается) не роняет наблюдение - следующий тик доберёт.
	КонецПопытки;
	Если Завершено Тогда
		ОтключитьОбработчикОжидания("ПрогрессТик");
		ИдЗадания = "";
		ОбновитьДоступностьПереноса();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьПереноса()
	Идёт = НЕ ПустаяСтрока(ИдЗадания);
	Элементы.ВыгрузитьКнопка.Доступность = НЕ Идёт;
	Элементы.ЗагрузитьКнопка.Доступность = НЕ Идёт;
	Элементы.ОтменаКнопкаВыгрузка.Доступность = Идёт;
	Элементы.ОтменаКнопкаЗагрузка.Доступность = Идёт;
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	Если НЕ ПроверитьПередЗапуском(Ложь) Тогда
		Возврат;
	КонецЕсли;
	// Валидируем источник ДО предупреждения об очистке: есть ли манифест и какие регистры затронет.
	Манифест = ПрочитатьРегистрыМанифеста(ПапкаОбмена);
	Если Манифест.Регистры = Неопределено Тогда
		ПоказатьПредупреждение(, Манифест.Ошибка);
		Возврат;
	КонецЕсли;
	// Очищающие режимы (0 Полная / 1 с пропуском) затирают данные приёмника — подтверждаем явным списком.
	Если РежимЗагрузки = 0 ИЛИ РежимЗагрузки = 1 Тогда
		Текст = СтрШаблон("Режим «%1» очистит и перезальёт в приёмнике регистры: %2. Продолжить?",
			ПредставлениеРежимаЗагрузки(), СтрСоединить(Манифест.Регистры, ", "));
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗагрузитьПодтверждение", ЭтотОбъект),
			Текст, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
	Иначе
		ВыполнитьЗагрузку();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПодтверждение(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ВыполнитьЗагрузку();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗагрузку()
	Если НЕ ПустаяСтрока(ИдЗадания) Тогда
		ПоказатьПредупреждение(, "Перенос уже выполняется. Дождитесь завершения или отмените.");
		Возврат;
	КонецЕсли;
	Попытка
		ЗапуститьЗагрузкуНаСервере();
	Исключение
		ПоказатьПредупреждение(, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	НачатьНаблюдениеПрогресса();
КонецПроцедуры

&НаКлиенте
Процедура ПолныйТест(Команда)
	ПолныйТестНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура НагрузочныйТест(Команда)
	НагрузочныйТестНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура ПараллельнаяВыгрузка(Команда)
	ПараллельнаяВыгрузкаНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура ПараллельнаяЗагрузка(Команда)
	ПараллельнаяЗагрузкаНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаУпаковки(Команда)
	ПроверкаУпаковкиНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура ПодборЧанка(Команда)
	ПодборЧанкаНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Процедура МатрицаФормата(Команда)
	МатрицаФорматаНаСервере();
	ПоказатьОтчёт();
КонецПроцедуры

&НаКлиенте
Функция ПроверитьПередЗапуском(ЭтоВыгрузка)
	Если ПустаяСтрока(ПапкаОбмена) Тогда
		ПоказатьПредупреждение(, "Укажите папку обмена.");
		Возврат Ложь;
	КонецЕсли;
	Если ЭтоВыгрузка И ПустаяСтрока(ИменаРегистров) Тогда
		ПоказатьПредупреждение(, "Выберите хотя бы один регистр для выгрузки.");
		Возврат Ложь;
	КонецЕсли;
	Возврат Истина;
КонецФункции

&НаКлиенте
Функция ПредставлениеРежимаЗагрузки()
	Если РежимЗагрузки = 0 Тогда
		Возврат "Полная перезаливка";
	ИначеЕсли РежимЗагрузки = 1 Тогда
		Возврат "Перезаливка, пропуская совпадающие";
	КонецЕсли;
	Возврат "Дозапись (без очистки)";
КонецФункции

&НаКлиенте
Процедура ПоказатьОтчёт()
	Элементы.СтраницыГлавная.ТекущаяСтраница = Элементы.Отчет;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗапуститьВыгрузкуНаСервере()
	Порция = ?(РазмерПорции > 0, РазмерПорции, 100000);
	Потоки = ?(ПотокиВыгрузки > 0, ПотокиВыгрузки, 1);
	Парам = Новый Массив;
	Парам.Добавить(ИменаРегистровМассивом());
	Парам.Добавить(ПапкаОбмена);
	Парам.Добавить(Порция);
	Парам.Добавить(Потоки);
	Парам.Добавить(Сжатие);
	Парам.Добавить(ФорматДанных);
	Парам.Добавить(НачалоПериода);
	Парам.Добавить(КонецПериода);
	ИдЗадания = Обработки.БыстрыйПереносРегистров.ЗапуститьПереносФоном("выгрузка", Парам);
	НаправлениеПереноса = "Выгрузка";
	ПапкаПереноса = ПапкаОбмена; // снимок: ПапкаОбмена могут поменять во время переноса
	ОтчётHTML = ПрогрессHTML(0, 0, "Выгрузка: запуск...");
КонецПроцедуры

&НаСервере
Процедура ЗапуститьЗагрузкуНаСервере()
	Потоки = ?(ПотокиЗагрузки > 0, ПотокиЗагрузки, 1); // потоки записи (профиль уже учёл: файловая ИБ → 1)
	// Режим: 0 Полная (чистим, без пропуска) / 1 Перезаливка с пропуском (чистим + пропуск) / 2 Дозапись (без очистки).
	ОчищатьЗагрузку = (РежимЗагрузки = 0 ИЛИ РежимЗагрузки = 1);
	ПропускЗагрузку = (РежимЗагрузки = 1);
	Парам = Новый Массив;
	Парам.Добавить(ПапкаОбмена);
	Парам.Добавить(ОчищатьЗагрузку);
	Парам.Добавить(Потоки);
	Парам.Добавить(ПропускЗагрузку);
	ИдЗадания = Обработки.БыстрыйПереносРегистров.ЗапуститьПереносФоном("загрузка", Парам);
	НаправлениеПереноса = "Загрузка";
	ПапкаПереноса = ПапкаОбмена;
	ОтчётHTML = ПрогрессHTML(0, 0, "Загрузка: запуск...");
КонецПроцедуры

&НаСервере
Функция ПрогрессТикНаСервере()
	Прогресс = Обработки.БыстрыйПереносРегистров.ПрогрессПереноса(ПапкаПереноса, ИдЗадания);
	Если Прогресс.Активно Тогда
		ОтчётHTML = ПрогрессHTML(Прогресс.Сделано, Прогресс.Всего, НаправлениеПереноса);
		Возврат Ложь;
	КонецЕсли;
	Шапка = НаправлениеПереноса + ": " + ?(Прогресс.Статус = "OK", "успешно завершено",
		?(Прогресс.Статус = "Отменено", "отменено", "ОШИБКА"));
	ОтчётHTML = НагрузочныйТест.ТекстКакHTML(Шапка + Символы.ПС + Символы.ПС + Прогресс.Лог);
	Возврат Истина;
КонецФункции

&НаСервере
Процедура ОтменитьПереносНаСервере()
	Обработки.БыстрыйПереносРегистров.ОтменитьПеренос(ИдЗадания);
КонецПроцедуры

// HTML живого прогресса: кролик 🐇 скачет по прогресс-полосе к морковке, позиция = процент.
// Инлайн SVG + CSS, без внешних ресурсов - рендерится в HTMLDocumentField любого клиента.
&НаСервереБезКонтекста
Функция ПрогрессHTML(Сделано, Всего, Заголовок)
	Процент = 0;
	Если Всего > 0 Тогда
		Процент = Окр(100 * Сделано / Всего);
		Если Процент > 100 Тогда
			Процент = 100;
		КонецЕсли;
	КонецЕсли;
	// ЧН=0 обязателен: Формат(0, "ЧГ=") в 1С даёт ПУСТУЮ строку - без него на старте
	// подпись теряет числа, а CSS width:"%" (невалидный) растягивает полосу на 100%.
	СтрПроцент = Формат(Процент, "ЧГ=; ЧН=0");
	Подпись = ?(Всего > 0,
		Формат(Сделано, "ЧГ=; ЧН=0") + " из " + Формат(Всего, "ЧГ=; ЧН=0") + " строк (" + СтрПроцент + "%)",
		"подготовка...");
	Возврат "<html><head><meta charset='utf-8'><style>"
