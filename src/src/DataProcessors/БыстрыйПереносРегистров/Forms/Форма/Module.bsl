&НаСервере
Процедура ЗапуститьВыгрузкуНаСервере()
	Порция = ?(РазмерПорции > 0, РазмерПорции, 100000);
	Потоки = ?(ПотокиВыгрузки > 0, ПотокиВыгрузки, 1);
	// ЗАР (ревью v2): выгрузка идёт в СВОЮ подпапку сеанса Run_* папки обмена - параллельные
	// прогоны не топчут друг друга, а зомби-воркеры отменённого прогона не могут подкинуть
	// чанки в манифест следующего. Загрузка находит свежайшую Run_* сама (ПапкаСМанифестом).
	ПапкаСеанса = Обработки.БыстрыйПереносРегистров.СоздатьПапкуСеанса(ПапкаОбмена);
	Парам = Новый Массив;
	Парам.Добавить(ИменаРегистровМассивом());
	Парам.Добавить(ПапкаСеанса);
	Парам.Добавить(Порция);
	Парам.Добавить(Потоки);
	Парам.Добавить(Сжатие);
	Парам.Добавить(ФорматДанных);
	Парам.Добавить(НачалоПериода);
	Парам.Добавить(КонецПериода);
	ИдЗадания = Обработки.БыстрыйПереносРегистров.ЗапуститьПереносФоном("выгрузка", Парам);
	НаправлениеПереноса = "Выгрузка";
	ПапкаПереноса = ПапкаСеанса; // снимок: прогресс/итог живут в подпапке сеанса
	ОтчётHTML = ПрогрессHTML(0, 0, "Выгрузка: запуск...");
КонецПроцедуры

&НаСервере
Процедура ЗапуститьЗагрузкуНаСервере()
	Потоки = ?(ПотокиЗагрузки > 0, ПотокиЗагрузки, 1); // потоки записи (профиль уже учёл: файловая ИБ → 1)
	// Режим: 0 Полная (чистим, без пропуска) / 1 Перезаливка с пропуском (чистим + пропуск) / 2 Дозапись (без очистки).
	ОчищатьЗагрузку = (РежимЗагрузки = 0 ИЛИ РежимЗагрузки = 1);
	ПропускЗагрузку = (РежимЗагрузки = 1);
	// Выгрузка из формы пишет в подпапку сеанса Run_* - грузим оттуда же (свежайший манифест).
	ПапкаИсточника = Обработки.БыстрыйПереносРегистров.ПапкаСМанифестом(ПапкаОбмена);
	Парам = Новый Массив;
	Парам.Добавить(ПапкаИсточника);
	Парам.Добавить(ОчищатьЗагрузку);
	Парам.Добавить(Потоки);
	Парам.Добавить(ПропускЗагрузку);
	ИдЗадания = Обработки.БыстрыйПереносРегистров.ЗапуститьПереносФоном("загрузка", Парам);
	НаправлениеПереноса = "Загрузка";
	ПапкаПереноса = ПапкаИсточника;
	ОтчётHTML = ПрогрессHTML(0, 0, "Загрузка: запуск...");
КонецПроцедуры

&НаСервере
Функция ПрогрессТикНаСервере()
	Прогресс = Обработки.БыстрыйПереносРегистров.ПрогрессПереноса(ПапкаПереноса, ИдЗадания);
	Если Прогресс.Активно Тогда
		ОтчётHTML = ПрогрессHTML(Прогресс.Сделано, Прогресс.Всего, НаправлениеПереноса);
		Возврат Ложь;
	КонецЕсли;
	Шапка = НаправлениеПереноса + ": " + ?(Прогресс.Статус = "OK", "успешно завершено",
		?(Прогресс.Статус = "Отменено", "отменено", "ОШИБКА"));
	ОтчётHTML = НагрузочныйТест.ТекстКакHTML(Шапка + Символы.ПС + Символы.ПС + Прогресс.Лог);
	Возврат Истина;
КонецФункции

&НаСервере
Процедура ОтменитьПереносНаСервере()
	Обработки.БыстрыйПереносРегистров.ОтменитьПеренос(ИдЗадания);
КонецПроцедуры

// HTML живого прогресса: кролик 🐇 скачет по прогресс-полосе к морковке, позиция = процент.
// Инлайн SVG + CSS, без внешних ресурсов - рендерится в HTMLDocumentField любого клиента.
&НаСервереБезКонтекста
Функция ПрогрессHTML(Сделано, Всего, Заголовок)
	Процент = 0;
	Если Всего > 0 Тогда
		Процент = Окр(100 * Сделано / Всего);
		Если Процент > 100 Тогда
			Процент = 100;
		КонецЕсли;
	КонецЕсли;
	// ЧН=0 обязателен: Формат(0, "ЧГ=") в 1С даёт ПУСТУЮ строку - без него на старте
	// подпись теряет числа, а CSS width:"%" (невалидный) растягивает полосу на 100%.
	СтрПроцент = Формат(Процент, "ЧГ=; ЧН=0");
	Подпись = ?(Всего > 0,
		Формат(Сделано, "ЧГ=; ЧН=0") + " из " + Формат(Всего, "ЧГ=; ЧН=0") + " строк (" + СтрПроцент + "%)",
		"подготовка...");
	Возврат "<html><head><meta charset='utf-8'><style>"
		+ "body{font-family:'Segoe UI',Arial,sans-serif;margin:16px;}"
		+ ".t{font-size:15px;font-weight:600;margin-bottom:4px;}"
		+ ".s{font-size:13px;color:#444;margin-bottom:14px;}"
		+ ".track{position:relative;height:72px;max-width:640px;}"
		+ ".bar{position:absolute;left:0;right:30px;bottom:12px;height:10px;background:#eee;border-radius:5px;}"
		+ ".fill{height:10px;width:" + СтрПроцент + "%;background:linear-gradient(90deg,#7bc96f,#2a9d3f);border-radius:5px;transition:width 1s;}"
		+ ".rab{position:absolute;bottom:20px;left:calc(" + СтрПроцент + "% - 17px);animation:hop .5s infinite;}"
		+ ".carrot{position:absolute;right:0;bottom:14px;font-size:22px;}"
		+ "@keyframes hop{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}"
		+ "</style></head><body>"
		+ "<div class='t'>" + Заголовок + "</div>"
		+ "<div class='s'>" + Подпись + "</div>"
		+ "<div class='track'>"
		+ "<div class='bar'><div class='fill'></div></div>"
		+ "<div class='rab'><svg width='34' height='28' viewBox='0 0 34 28'>"
		+ "<ellipse cx='14' cy='20' rx='11' ry='7' fill='#bfc6d1'/>"
		+ "<circle cx='25' cy='14' r='5' fill='#bfc6d1'/>"
		+ "<ellipse cx='23' cy='6' rx='1.8' ry='5.5' fill='#bfc6d1'/>"
		+ "<ellipse cx='27' cy='6' rx='1.8' ry='5.5' fill='#d9adad'/>"
		+ "<circle cx='26.5' cy='13' r='0.9' fill='#333'/>"
		+ "<circle cx='4' cy='22' r='2.6' fill='#e8ecf2'/>"
		+ "</svg></div>"
		+ "<div class='carrot'>🥕</div>"
		+ "</div></body></html>";
КонецФункции

&НаСервере
Процедура ПрименитьПрофиль()
	// Пресеты под СУБД приёмника: порция + раздельные потоки выгрузки/загрузки.
	// «Вручную» (3) значения не меняет — только обновляем видимость.
	Если ПрофильСреды = 0 Тогда // Файловая ИБ
		РазмерПорции = 100000; // крупные чанки: файловая ИБ упирается в I/O, не в блокировки СУБД
		ПотокиВыгрузки = 4;    // выгрузка-чтение распараллеливается
		// ЗАР: файловая ИБ — единственный писатель (.1CD под монопольной защёлкой),
		// параллельная загрузка лишь создаёт конкуренцию за файл → грузим в 1 поток.
		ПотокиЗагрузки = 1;
		Сжатие = 0;
	ИначеЕсли ПрофильСреды = 1 Тогда // MS SQL Server
		// ЗАР: MS SQL эскалирует построчные блокировки в табличную при ~5000 блокировок на транзакцию.
		// Порцию загрузки держим < 5000 строк → заливка идёт без эскалации и не лочит таблицу целиком.
		РазмерПорции = 4000;
		ПотокиВыгрузки = 4;
		ПотокиЗагрузки = 4;
		Сжатие = 0;
	ИначеЕсли ПрофильСреды = 2 Тогда // PostgreSQL
		РазмерПорции = 50000; // нет построчной эскалации блокировок; крупнее чанк → меньше overhead на коммитах
		ПотокиВыгрузки = 4;
		ПотокиЗагрузки = 4;
		Сжатие = 0;
	ИначеЕсли ПрофильСреды = 4 Тогда // Экстремальный режим — максимальная пропускная способность
		РазмерПорции = 50000;
		ПотокиВыгрузки = 16;  // выгрузка-чтение масштабируется агрессивно
		ПотокиЗагрузки = 4;   // загрузка-запись остаётся умеренной
		Сжатие = 0;
	КонецЕсли;
	ОбновитьВидимостьНастроек();
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимостьНастроек()
	// Профиль задаёт настройки сам — показываем их read-only (виден пресет), редактировать
	// можно в режиме разработчика или при профиле «Вручную». Вкладка «Бенчмарк» — только дев.
	Заблокировать = НЕ (РежимРазработчика ИЛИ ПрофильСреды = 3);
	Элементы.Сжатие.ТолькоПросмотр = Заблокировать;
	Элементы.ПотокиВыгрузки.ТолькоПросмотр = Заблокировать;
	Элементы.ПотокиЗагрузки.ТолькоПросмотр = Заблокировать;
	Элементы.РазмерПорции1.ТолькоПросмотр = Заблокировать;
	Элементы.Бенчмарк.Видимость = РежимРазработчика;
КонецПроцедуры

&НаСервере
Функция ПрочитатьРегистрыМанифеста(Папка)
	// Ответ (не «Результат»: так зовётся орфанный реквизит формы — коллизия имён).
	Ответ = Новый Структура("Регистры, Ошибка, Папка", Неопределено, "", Папка);
	Попытка
		// Резолвим источник как загрузка: manifest.json в самой папке или свежайшая подпапка Run_*.
		Ответ.Папка = Обработки.БыстрыйПереносРегистров.ПапкаСМанифестом(Папка);
		Имена = Обработки.БыстрыйПереносРегистров.РегистрыМанифеста(Ответ.Папка);
	Исключение
		Ответ.Ошибка = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ответ;
	КонецПопытки;
	Если Имена = Неопределено Тогда
		Ответ.Ошибка = "В папке обмена не найден manifest.json (ни в самой папке, ни в подпапках Run_*). Проверьте путь к папке.";
	Иначе
		Ответ.Регистры = Имена;
	КонецЕсли;
	Возврат Ответ;
КонецФункции

&НаСервере
Функция ОпределитьПрофильСреды()
	// Файловую vs клиент-серверную ИБ видно из строки соединения; конкретную СУБД сервера
	// (MS SQL / PostgreSQL) платформа прикладному коду не отдаёт → для сервера берём
	// консервативный пресет MS SQL (мелкая порция), пользователь при нужде переключит на PostgreSQL.
	СтрокаСоединения = ВРег(СтрокаСоединенияИнформационнойБазы());
	Если СтрНайти(СтрокаСоединения, "FILE=") > 0 Тогда
		Возврат 0; // файловая ИБ
	КонецЕсли;
	Возврат 1; // клиент-сервер → MS SQL (консервативно)
КонецФункции

// === Панель тестов: серверная часть ===

// Заполняет план из каталога тестов харнесса; перф-пресеты дополнительно ставят профиль СУБД.
&НаСервере
Процедура ЗаполнитьПресетНаСервере(ИмяПресета)

	ПланТестов.Очистить();
	Для Каждого Тест Из НагрузочныйТест.КаталогТестов() Цикл
		Включать = Ложь;
		Строк = Тест.КоличествоСтрок;
		Порция = Тест.РазмерПорции;
		Если ИмяПресета = "Смоук" Тогда
			Включать = (Тест.Категория = "Сборочный");
			Если Тест.Идентификатор = "ОтменаЗомби" Тогда
				Строк = 300000; // окно отмены ещё ловится, а прогон быстрее
			КонецЕсли;
		ИначеЕсли ИмяПресета = "ПерфФайловая" Тогда
			Включать = (Тест.Категория = "Бенчмарк" И Тест.Идентификатор <> "ПараллельнаяЗагрузка"
				И Тест.Идентификатор <> "МатрицаФорматов");
			Строк = ?(Тест.Идентификатор = "Упаковка", Тест.КоличествоСтрок, 1000000);
			Порция = ?(Порция > 0, 100000, 0);
		ИначеЕсли ИмяПресета = "ПерфMSSQL" Тогда
			Включать = (Тест.Категория = "Бенчмарк");
			Строк = ?(Тест.Идентификатор = "Упаковка", Тест.КоличествоСтрок, 1000000);
			// ЗАР: порция < 5000 - под порог эскалации блокировок MS SQL (см. ПрименитьПрофиль).
			Порция = ?(Порция > 0, 4000, 0);
		КонецЕсли;
		НоваяСтрока = ПланТестов.Добавить();
		НоваяСтрока.Включен = Включать;
		НоваяСтрока.Идентификатор = Тест.Идентификатор;
		НоваяСтрока.Представление = Тест.Представление;
		НоваяСтрока.Категория = Тест.Категория;
		НоваяСтрока.КоличествоСтрок = Строк;
		НоваяСтрока.РазмерПакета = Тест.РазмерПакета;
		НоваяСтрока.РазмерПорции = Порция;
		НоваяСтрока.Статус = "";
		НоваяСтрока.Длительность = "";
		НоваяСтрока.Вердикт = "";
	КонецЦикла;

	Если ИмяПресета = "ПерфФайловая" Тогда
		ПрофильСреды = 0;
		ПрименитьПрофиль();
	ИначеЕсли ИмяПресета = "ПерфMSSQL" Тогда
		ПрофильСреды = 1;
		ПрименитьПрофиль();
	КонецЕсли;
	СохранитьПланВНастройках();

КонецПроцедуры

// Реквизит-ТаблицуЗначений платформа НЕ сохраняет в настройках данных формы (savedInSettings
// работает только для примитивов) - храним план явно: JSON-строкой в ХранилищеОбщихНастроек.
&НаСервере
Процедура СохранитьПланВНастройках()

	Массив = Новый Массив;
	Для Каждого Строчка Из ПланТестов Цикл
		Элемент = Новый Структура("Идентификатор, Включен, КоличествоСтрок, РазмерПакета, РазмерПорции, Статус, Длительность, Вердикт");
		ЗаполнитьЗначенияСвойств(Элемент, Строчка);
		Массив.Добавить(Элемент);
	КонецЦикла;
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Массив);
	ХранилищеОбщихНастроек.Сохранить("ОбработкаБыстрыйПереносРегистров", "ПланТестов", Запись.Закрыть());

КонецПроцедуры

&НаСервере
Функция ЗагрузитьПланИзНастроек()

	Сохранено = ХранилищеОбщихНастроек.Загрузить("ОбработкаБыстрыйПереносРегистров", "ПланТестов");
	Если ТипЗнч(Сохранено) <> Тип("Строка") Или ПустаяСтрока(Сохранено) Тогда
		Возврат Ложь;
	КонецЕсли;
	Попытка
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(Сохранено);
		ДанныеПлана = ПрочитатьJSON(Чтение, Истина);
	Исключение
		Возврат Ложь; // битые настройки - молча уходим на пресет
	КонецПопытки;
	Если ТипЗнч(ДанныеПлана) <> Тип("Массив") Тогда
		Возврат Ложь;
	КонецЕсли;

	Каталог = Новый Соответствие;
	Для Каждого Тест Из НагрузочныйТест.КаталогТестов() Цикл
		Каталог.Вставить(Тест.Идентификатор, Тест);
	КонецЦикла;
	ПланТестов.Очистить();
	Для Каждого Элемент Из ДанныеПлана Цикл
		Тест = Каталог[Элемент["Идентификатор"]];
		Если Тест = Неопределено Тогда
			Продолжить; // тест исчез из каталога - строку не тащим
		КонецЕсли;
		НоваяСтрока = ПланТестов.Добавить();
		НоваяСтрока.Идентификатор = Тест.Идентификатор;
		НоваяСтрока.Представление = Тест.Представление;
		НоваяСтрока.Категория = Тест.Категория;
		НоваяСтрока.Включен = (Элемент["Включен"] = Истина);
		НоваяСтрока.КоличествоСтрок = ЧислоИзНастройки(Элемент["КоличествоСтрок"]);
		НоваяСтрока.РазмерПакета = ЧислоИзНастройки(Элемент["РазмерПакета"]);
		НоваяСтрока.РазмерПорции = ЧислоИзНастройки(Элемент["РазмерПорции"]);
		НоваяСтрока.Статус = СтрокаИзНастройки(Элемент["Статус"]);
		НоваяСтрока.Длительность = СтрокаИзНастройки(Элемент["Длительность"]);
		НоваяСтрока.Вердикт = СтрокаИзНастройки(Элемент["Вердикт"]);
	КонецЦикла;
	Возврат ПланТестов.Количество() > 0;

КонецФункции

&НаСервереБезКонтекста
Функция ЧислоИзНастройки(Значение)
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат 0;
КонецФункции

&НаСервереБезКонтекста
Функция СтрокаИзНастройки(Значение)
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат "";
КонецФункции

// План восстановился из настроек - выкидываем строки с неизвестными каталогу идентификаторами
// (страховка от дрейфа состава тестов между версиями) и добавляем недостающие выключенными.
&НаСервере
Процедура НормализоватьПлан()

	Известные = Новый Соответствие;
	Для Каждого Тест Из НагрузочныйТест.КаталогТестов() Цикл
		Известные.Вставить(Тест.Идентификатор, Тест);
	КонецЦикла;

	Индекс = ПланТестов.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Если Известные[ПланТестов[Индекс].Идентификатор] = Неопределено Тогда
			ПланТестов.Удалить(Индекс);
		Иначе
			Известные.Удалить(ПланТестов[Индекс].Идентификатор);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	Для Каждого КЗ Из Известные Цикл
		НоваяСтрока = ПланТестов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, КЗ.Значение);
		НоваяСтрока.Включен = Ложь;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура НачатьОтчётПланаНаСервере()
	ОтчётПлана = "";
КонецПроцедуры

&НаСервере
Процедура ПоказатьАнимациюНаСервере(Индекс)
	Строчка = ПланТестов[Индекс];
	Терминал = "> run " + Строчка.Идентификатор
		+ ?(Строчка.КоличествоСтрок > 0, " --rows " + Формат(Строчка.КоличествоСтрок, "ЧГ=; ЧН=0"), "");
	АнимацияHTML = АнимацияСервисногоРежимаHTML(Терминал);
КонецПроцедуры

// Один шаг плана: собирает параметры из строки таблицы + общих настроек формы,
// зовёт диспетчер харнесса, пишет результат в строку и дописывает сводный отчёт.
&НаСервере
Процедура ВыполнитьШагНаСервере(Индекс)

	Строчка = ПланТестов[Индекс];
	// ЗАР: НЕ называть переменную «Параметры» - это встроенное read-only свойство формы,
	// локальное имя привязывается к нему и падает «Поле объекта недоступно для записи».
	ПараметрыШага = Новый Структура;
	ПараметрыШага.Вставить("Папка", ПапкаОбмена);
	ПараметрыШага.Вставить("КоличествоСтрок", Строчка.КоличествоСтрок);
	ПараметрыШага.Вставить("РазмерПакета", ?(Строчка.РазмерПакета > 0, Строчка.РазмерПакета, 50000));
	ПараметрыШага.Вставить("РазмерПорции", Строчка.РазмерПорции);
	ПараметрыШага.Вставить("Регистр", ?(ПустаяСтрока(РегистрТеста), НагрузочныйТест.ИмяСинтетическогоРегистра(), СокрЛП(РегистрТеста)));
	ПараметрыШага.Вставить("Потоки", ?(ПотокиВыгрузки > 0, ПотокиВыгрузки, 4));
	ПараметрыШага.Вставить("Сжатие", Сжатие);
	ПараметрыШага.Вставить("Формат", ФорматДанных);

	Результат = НагрузочныйТест.ВыполнитьШагПлана(Строчка.Идентификатор, ПараметрыШага);

	Строчка.Статус = ?(Результат.Успех, "✅ OK", "❌ FAIL");
	Строчка.Длительность = ?(Результат.ДлительностьМс < 1000,
		Формат(Результат.ДлительностьМс, "ЧГ=; ЧН=0") + " мс",
		Формат(Результат.ДлительностьМс / 1000, "ЧДЦ=1; ЧН=0") + " с");
	Строчка.Вердикт = Результат.Вердикт;

	// Секция подробностей шага в накопительный отчёт (инкрементально переживает обрыв).
	ОтчётПлана = ОтчётПлана
		+ "<details><summary><b>" + Строчка.Представление + "</b> — " + Строчка.Статус
		+ " (" + Строчка.Длительность + ")</summary>" + ТелоHTML(Результат.HTML) + "</details>";
	ЗаписатьФайлОтчётаПлана(СводныйОтчётПланаHTML());

КонецПроцедуры

&НаСервере
Процедура ЗавершитьПланНаСервере()
	ОтчётHTML = СводныйОтчётПланаHTML();
	ЗаписатьФайлОтчётаПлана(ОтчётHTML);
	СохранитьПланВНастройках(); // статусы прогона переживают сеанс
КонецПроцедуры

// Сводка: таблица шагов + разворачиваемые подробности каждого выполненного шага.
&НаСервере
Функция СводныйОтчётПланаHTML()
	Стр = Новый Массив;
	Стр.Добавить("<html><head><meta charset='utf-8'><style>"
		+ "body{font-family:'Segoe UI',Arial,sans-serif;font-size:13px;margin:8px;}"
		+ "table{border-collapse:collapse;margin-bottom:12px;}"
		+ "td,th{border:1px solid #c8c8c8;padding:4px 10px;text-align:left;}"
		+ "th{background:#f2f2f2;} details{margin:6px 0;} summary{cursor:pointer;}"
		+ "</style></head><body><h3>План тестов</h3>"
		+ "<table><tr><th></th><th>Категория</th><th>Тест</th><th>Статус</th><th>Время</th><th>Вердикт</th></tr>");
	Для Каждого Строчка Из ПланТестов Цикл
		Стр.Добавить("<tr><td>" + ?(Строчка.Включен, "☑", "☐") + "</td><td>" + Строчка.Категория
			+ "</td><td>" + Строчка.Представление + "</td><td>" + Строчка.Статус
			+ "</td><td>" + Строчка.Длительность + "</td><td>"
			+ НагрузочныйТест.ТекстКакHTML(Строчка.Вердикт) + "</td></tr>");
	КонецЦикла;
	Стр.Добавить("</table>");
	Стр.Добавить(ОтчётПлана);
	Стр.Добавить("</body></html>");
	Возврат СтрСоединить(Стр, "");
КонецФункции

// Содержимое между <body> и </body> (вложить готовый HTML шага внутрь сводки без второй обёртки).
&НаСервереБезКонтекста
Функция ТелоHTML(HTML)
	ПозТела = СтрНайти(HTML, "<body>");
	ПозКонца = СтрНайти(HTML, "</body>");
	Если ПозТела = 0 ИЛИ ПозКонца = 0 Тогда
		Возврат HTML;
	КонецЕсли;
	Возврат Сред(HTML, ПозТела + 6, ПозКонца - ПозТела - 6);
КонецФункции

&НаСервере
Процедура ЗаписатьФайлОтчётаПлана(Текст)
	Попытка
		Запись = Новый ЗаписьТекста(ПапкаОбмена + "\test_plan_report.html", КодировкаТекста.UTF8);
		Запись.Записать(Текст);
		Запись.Закрыть();
	Исключение
		// Файл не критичен - отчёт всё равно уходит в форму.
	КонецПопытки;
КонецПроцедуры

// Анимация «сервисного режима» (арт пользователя: сова-разработчик, кофе, святой дым).
// Параметризована только первая строка терминала - текущий шаг плана.
// ЗАР: CSS-анимация в iframe HTMLDocumentField живёт ДАЖЕ пока клиент заморожен синхронным
// вызовом - индикатор «не сдохло» для минутных шагов, где фоновый паттерн (кролик) не применим.
&НаСервереБезКонтекста
Функция АнимацияСервисногоРежимаHTML(СтрокаТерминала)
	// Палитра Catppuccin (тёмная хакерская эстетика, приятная глазу)
	Возврат "<html><head><meta charset='utf-8'><style>"
		+ "body { margin:0; padding:0; font-family:'Consolas','Courier New',monospace; overflow:hidden; }"
		+ ".dev-panel { display:flex; align-items:center; justify-content:space-between; background:#181825; border:1px solid #313244; border-radius:8px; padding:12px 20px; box-shadow:inset 0 2px 10px rgba(0,0,0,0.5); height:70px; position:relative; }"
		+ ".bg-code { position:absolute; top:-50px; right:40px; color:#313244; font-size:10px; line-height:1.2; z-index:1; user-select:none; animation:matrix 20s linear infinite; white-space:pre; }"
		+ ".term { color:#a6e3a1; font-size:13px; line-height:1.6; z-index:2; }"
		+ ".term span { display:block; opacity:0; animation:type 0.1s forwards; }"
		+ ".term span:nth-child(1) { animation-delay:0.2s; }"
		+ ".term span:nth-child(2) { animation-delay:0.8s; color:#f9e2af; }"
		+ ".term span:nth-child(3) { animation-delay:1.4s; }"
		+ ".cursor { display:inline-block; width:7px; height:13px; background:#a6e3a1; animation:blink 1s step-end infinite; vertical-align:-1px; margin-left:4px; }"
		+ ".art { position:relative; width:100px; height:80px; z-index:2; }"
		+ ".steam { stroke-dasharray:10; stroke-dashoffset:20; animation:smoke 2.5s infinite linear; }"
		+ ".s2 { animation-delay:1.2s; }"
		+ ".blink-layer { transform-origin:center 20px; transform:scaleY(0); animation:blink-eyes 6s infinite; }"
		+ ".pupil { animation:look 8s infinite; }"
		+ ".glow { animation:pulse 2s infinite alternate; }"
		+ "@keyframes type { to { opacity:1; } }"
		+ "@keyframes blink { 0%, 100% { opacity:1; } 50% { opacity:0; } }"
		+ "@keyframes smoke { to { stroke-dashoffset:0; opacity:0; transform:translateY(-8px); } }"
		+ "@keyframes blink-eyes { 0%, 96%, 100% { transform:scaleY(0); } 98% { transform:scaleY(1); } }"
		+ "@keyframes look { 0%, 20%, 100% { transform:translateX(0); } 30%, 50% { transform:translateX(-2px); } 60%, 80% { transform:translateX(2px); } }"
		+ "@keyframes pulse { to { fill:#f38ba8; filter:drop-shadow(0 0 3px #f38ba8); } }"
		+ "@keyframes matrix { from { transform:translateY(0); } to { transform:translateY(120px); } }"
		+ "</style></head><body>"
		+ "<div class='dev-panel'>"
		+ "<div class='bg-code'>"
		+ "10101101 01100010<br>01000101 11010010<br>11100011 00110101<br>"
		+ "01010101 11001100<br>10101010 00110011<br>01101100 10101111<br>"
		+ "00011100 01101001<br>11001010 01010101<br>10101101 01100010"
		+ "</div>"
		+ "<div class='term'>"
		+ "<span>" + НагрузочныйТест.ЭкранированиеHTML(СтрокаТерминала) + "</span>"
		+ "<span>> loading coffee.dll... [OK]</span>"
		+ "<span>> sys.status: AWAKE <div class='cursor'></div></span>"
		+ "</div>"
		+ "<div class='art'>"
		+ "<svg width='100' height='80' viewBox='0 0 100 80'>"
		// Ноутбук
		+ "<path d='M 10 75 L 80 75 L 70 55 L 20 55 Z' fill='#45475a'/>"
		+ "<path d='M 5 80 L 85 80 L 80 75 L 10 75 Z' fill='#585b70'/>"
		+ "<circle cx='45' cy='65' r='4' fill='#f9e2af' class='glow'/>"
		// Тело совы
		+ "<ellipse cx='50' cy='40' rx='18' ry='22' fill='#313244'/>"
		+ "<ellipse cx='50' cy='45' rx='14' ry='16' fill='#45475a'/>"
		// Уши
		+ "<polygon points='32,22 36,8 42,20' fill='#313244'/>"
		+ "<polygon points='68,22 64,8 58,20' fill='#313244'/>"
		// Глаза (основа)
		+ "<circle cx='41' cy='30' r='7.5' fill='#cdd6f4'/>"
		+ "<circle cx='59' cy='30' r='7.5' fill='#cdd6f4'/>"
		// Зрачки (анимированные)
		+ "<circle cx='41' cy='30' r='3' fill='#11111b' class='pupil'/>"
		+ "<circle cx='59' cy='30' r='3' fill='#11111b' class='pupil'/>"
		// Клюв
		+ "<polygon points='48,34 52,34 50,39' fill='#f9e2af'/>"
		// Веки (анимация моргания)
		+ "<rect x='30' y='20' width='40' height='15' fill='#313244' class='blink-layer'/>"
		// Чашка кофе
		+ "<rect x='75' y='55' width='10' height='14' rx='2' fill='#bac2de'/>"
		+ "<path d='M 85 58 C 90 58, 90 66, 85 66' fill='none' stroke='#bac2de' stroke-width='2.5'/>"
		// Святой дым / Пар
		+ "<path d='M 77 50 Q 80 44 77 38 T 77 30' fill='none' stroke='#a6adc8' stroke-width='1.5' class='steam s1'/>"
		+ "<path d='M 82 52 Q 85 46 82 40 T 82 32' fill='none' stroke='#a6adc8' stroke-width='1.5' class='steam s2'/>"
		+ "</svg></div></div></body></html>";
КонецФункции

&НаСервере
Функция НастройкиRMQ()
	Возврат Новый Структура("ПутьККомпоненте, Хост, Порт, Пользователь, Пароль, ВиртуальныйХост, Очередь",
		ПутьККомпонентеRMQ, ХостRMQ, ПортRMQ, ПользовательRMQ, ПарольRMQ, "/", ОчередьRMQ);
КонецФункции

&НаСервере
Процедура ОтправитьВОчередьНаСервере()
	// Выгрузка из формы лежит в подпапке сеанса Run_* — отправляем свежайший манифест, как загрузка.
	Папка = Обработки.БыстрыйПереносРегистров.ПапкаСМанифестом(ПапкаОбмена);
	Лог = Обработки.БыстрыйПереносРегистров.ОтправитьПапкуВОчередь(Папка, НастройкиRMQ());
	ОтчётHTML = НагрузочныйТест.ТекстКакHTML("Отправка в RabbitMQ: успешно" + Символы.ПС + Символы.ПС + Лог);
КонецПроцедуры

&НаСервере
Процедура ПринятьИзОчередиНаСервере()
	// Приём - в ОТДЕЛЬНУЮ папку: докажет транспорт (файлы совпадают побайтово),
	// и оттуда можно грузить, переключив «Папка обмена».
	Лог = Обработки.БыстрыйПереносРегистров.ПринятьПапкуИзОчереди(ПапкаПриёмаRMQ, НастройкиRMQ(), 3000, ПапкаОбмена);
	ОтчётHTML = НагрузочныйТест.ТекстКакHTML("Приём из RabbitMQ: успешно" + Символы.ПС + Символы.ПС + Лог);
КонецПроцедуры

&НаСервере
Функция ИменаРегистровМассивом()
	Массив = Новый Массив;
	Для Каждого Элемент Из СтрРазделить(ИменаРегистров, "," + Символы.ПС + Символы.ВК, Ложь) Цикл
		Имя = СокрЛП(Элемент);
		Если НЕ ПустаяСтрока(Имя) Тогда
			Массив.Добавить(Имя);
		КонецЕсли;
	КонецЦикла;
	Возврат Массив;
КонецФункции

&НаСервере
Функция СписокРегистровДляВыбора()
	Текущие = Новый Соответствие;
	Для Каждого Стр Из СтрРазделить(ИменаРегистров, "," + Символы.ПС + Символы.ВК, Ложь) Цикл
		Имя = СокрЛП(Стр);
		Если НЕ ПустаяСтрока(Имя) Тогда
			Текущие.Вставить(Имя, Истина);
		КонецЕсли;
	КонецЦикла;
	Список = Новый СписокЗначений;
	ДобавитьРегистрыВСписок(Список, Метаданные.РегистрыСведений, "РС", Текущие);
	ДобавитьРегистрыВСписок(Список, Метаданные.РегистрыНакопления, "РН", Текущие);
	ДобавитьРегистрыВСписок(Список, Метаданные.РегистрыБухгалтерии, "РБ", Текущие);
	Возврат Список;
КонецФункции

&НаСервере
Процедура ДобавитьРегистрыВСписок(Список, Коллекция, Префикс, Текущие)
	Для Каждого Рег Из Коллекция Цикл
		Список.Добавить(Рег.Имя, "[" + Префикс + "] " + Рег.Имя, (Текущие[Рег.Имя] = Истина));
	КонецЦикла;
КонецПроцедуры

#КонецОбласти
